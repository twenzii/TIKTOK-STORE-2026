If you require assistance or have questions regarding this code, please contact support@versio.studio.
{% endcomment %}

{%- liquid
  assign mobile_gap = section.settings.mobile_gap
  assign padding_horizontal = section.settings.padding_horizontal
  assign padding_horizontal_mobile = section.settings.padding_horizontal_mobile
  assign section_full_width = section.settings.section_full_width
  assign section_max_width = section.settings.section_max_width
  assign text_container_max_width = section.settings.text_container_max_width
  assign content_testimonial_gap = section.settings.content_testimonial_gap
-%}

{%- style -%}
  {% if section.settings.custom_title_font %}
    {{ section.settings.title_font | font_face: font_display: 'swap' }}
  {% endif %}
  {% if section.settings.custom_subtitle_font %}
    {{ section.settings.subtitle_font | font_face: font_display: 'swap' }}
  {% endif %}
  {% if section.settings.custom_description_font %}
    {{ section.settings.description_font | font_face: font_display: 'swap' }}
  {% endif %}
  {% if section.settings.custom_testimonial_title_font %}
    {{ section.settings.testimonial_title_font | font_face: font_display: 'swap' }}
  {% endif %}
  {% if section.settings.custom_testimonial_content_font %}
    {{ section.settings.testimonial_content_font | font_face: font_display: 'swap' }}
  {% endif %}
  {% if section.settings.custom_author_name_font %}
    {{ section.settings.author_name_font | font_face: font_display: 'swap' }}
  {% endif %}
  {% if section.settings.custom_author_location_font %}
    {{ section.settings.author_location_font | font_face: font_display: 'swap' }}
  {% endif %}
  {% if section.settings.custom_author_date_font %}
    {{ section.settings.author_date_font | font_face: font_display: 'swap' }}
  {% endif %}

  {% if section.settings.custom_title_font %}
    #testimonials-05-{{ section.id }} .vso-testimonials-05__title {
      font-family: {{ section.settings.title_font.family }}, {{ section.settings.title_font.fallback_families }};
      font-style: {{ section.settings.title_font.style }};
    }
  {% endif %}

  {% if section.settings.custom_subtitle_font %}
    #testimonials-05-{{ section.id }} .vso-testimonials-05__subtitle {
      font-family: {{ section.settings.subtitle_font.family }}, {{ section.settings.subtitle_font.fallback_families }};
      font-style: {{ section.settings.subtitle_font.style }};
    }
  {% endif %}

  {% if section.settings.custom_description_font %}
    #testimonials-05-{{ section.id }} .vso-testimonials-05__description {
      font-family: {{ section.settings.description_font.family }}, {{ section.settings.description_font.fallback_families }};
      font-style: {{ section.settings.description_font.style }};
    }
  {% endif %}

  {% if section.settings.custom_testimonial_title_font %}
    #testimonials-05-{{ section.id }} .vso-testimonials-05__testimonial-title {
      font-family: {{ section.settings.testimonial_title_font.family }}, {{ section.settings.testimonial_title_font.fallback_families }};
      font-style: {{ section.settings.testimonial_title_font.style }};
    }
  {% endif %}

  {% if section.settings.custom_testimonial_content_font %}
    #testimonials-05-{{ section.id }} .vso-testimonials-05__testimonial-content {
      font-family: {{ section.settings.testimonial_content_font.family }}, {{ section.settings.testimonial_content_font.fallback_families }};
      font-style: {{ section.settings.testimonial_content_font.style }};
    }
  {% endif %}

  {% if section.settings.custom_author_name_font %}
    #testimonials-05-{{ section.id }} .vso-testimonials-05__author-name {
      font-family: {{ section.settings.author_name_font.family }}, {{ section.settings.author_name_font.fallback_families }};
      font-style: {{ section.settings.author_name_font.style }};
    }
  {% endif %}

  {% if section.settings.custom_author_location_font %}
    #testimonials-05-{{ section.id }} .vso-testimonials-05__author-location {
      font-family: {{ section.settings.author_location_font.family }}, {{ section.settings.author_location_font.fallback_families }};
      font-style: {{ section.settings.author_location_font.style }};
    }
  {% endif %}

  {% if section.settings.custom_author_date_font %}
    #testimonials-05-{{ section.id }} .vso-testimonials-05__author-date {
      font-family: {{ section.settings.author_date_font.family }}, {{ section.settings.author_date_font.fallback_families }};
      font-style: {{ section.settings.author_date_font.style }};
    }
  {% endif %}

  .vso-testimonials-05 {
    padding: 0;
    {% unless section_full_width %}
      max-width: {{ section_max_width }}px;
      margin: 0 auto;
    {% endunless %}
    overflow: visible !important;
  }

  .vso-testimonials-05__container {
    display: flex;
    align-items: center;
    gap: {{ content_testimonial_gap }}px;
    padding: 0 {{ padding_horizontal_mobile }}px;
    overflow: visible !important;
  }

  .vso-testimonials-05__content {
    flex: 1;
    max-width: {{ text_container_max_width }}px;
    text-align: {{ section.settings.content_alignment_desktop }};
  }

  .vso-node { display: none; }
  .vso-node--v2 { display: block; }

  {% if section.settings.custom_subtitle_font %}
    .vso-testimonials-05__subtitle {
      font-size: {{ section.settings.subtitle_size_desktop }}px;
      color: {{ section.settings.subtitle_color }};
      font-weight: {{ section.settings.subtitle_font_weight }};
      line-height: {{ section.settings.subtitle_line_height }}%;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      background-color: {{ section.settings.subtitle_bg_color }};
      padding: {{ section.settings.subtitle_padding_vertical }}px {{ section.settings.subtitle_padding_horizontal }}px;
      border-radius: {{ section.settings.subtitle_border_radius }}px;
      display: inline-flex;
      align-items: center;
      gap: {{ section.settings.subtitle_dot_spacing }}px;
    }

    .vso-testimonials-05__subtitle-dot {
      width: {{ section.settings.subtitle_dot_size }}px;
      height: {{ section.settings.subtitle_dot_size }}px;
      background-color: {{ section.settings.subtitle_dot_color }};
      border-radius: 50%;
      flex-shrink: 0;
      display: inline-block;
      {% if section.settings.enable_subtitle_dot_pulse %}
        -webkit-animation: vso-pulse-{{ section.id }} 2s infinite;
        animation: vso-pulse-{{ section.id }} 2s infinite;
      {% endif %}
    }

    {% if section.settings.enable_subtitle_dot_pulse %}
      @-webkit-keyframes vso-pulse-{{ section.id }} {
        0% {
          opacity: 1;
          transform: scale(1);
        }
        50% {
          opacity: 0.4;
          transform: scale(1.5);
        }
        100% {
          opacity: 1;
          transform: scale(1);
        }
      }
      @keyframes vso-pulse-{{ section.id }} {
        0% {
          opacity: 1;
          transform: scale(1);
        }
        50% {
          opacity: 0.4;
          transform: scale(1.5);
        }
        100% {
          opacity: 1;
          transform: scale(1);
        }
      }
    {% endif %}
  {% endif %}

  .vso-testimonials-05__subtitle {
    margin: 0 0 {{ section.settings.subtitle_margin_bottom }}px 0;
  }

  .vso-testimonials-05__title {
    margin: 0 0 {{ section.settings.title_margin_bottom }}px 0;
  }

  .vso-testimonials-05__description {
    margin: 0 0 {{ section.settings.description_margin_bottom }}px 0;
  }

  {% if section.settings.custom_title_font %}
    .vso-testimonials-05__title {
      font-size: {{ section.settings.title_size_desktop }}px;
      color: {{ section.settings.title_color }};
      font-weight: {{ section.settings.title_font_weight }};
      line-height: {{ section.settings.title_line_height }}%;
    }
  {% endif %}

  {% if section.settings.custom_description_font %}
    .vso-testimonials-05__description {
      font-size: {{ section.settings.description_size_desktop }}px;
      color: {{ section.settings.description_color }};
      font-weight: {{ section.settings.description_font_weight }};
      line-height: {{ section.settings.description_line_height }}%;
    }
  {% endif %}

  .vso-testimonials-05__stats {
    display: flex;
    justify-content: {{ section.settings.stats_alignment_desktop }};
    gap: {{ section.settings.stats_gap }}px;
    margin-top: {{ section.settings.stats_margin_top }}px;
  }

  .vso-testimonials-05__stat {
    text-align: {{ section.settings.stat_numbers_alignment_desktop }};
    position: relative;
  }

  .vso-testimonials-05__stat:not(:last-child)::after {
    content: '';
    position: absolute;
    right: calc(-{{ section.settings.stats_gap }}px / 2);
    top: 50%;
    transform: translateY(-50%);
    width: 1px;
    height: 40px;
    background-color: {{ section.settings.stat_divider_color }};
  }

  .vso-testimonials-05__stat-number {
    margin: 0 0 4px 0;
    font-size: {{ section.settings.stat_number_size_desktop }}px;
    color: {{ section.settings.stat_number_color }};
    font-weight: {{ section.settings.stat_number_font_weight }};
    line-height: 1.2;
  }

  .vso-testimonials-05__stat-label {
    margin: 0;
    font-size: {{ section.settings.stat_label_size_desktop }}px;
    color: {{ section.settings.stat_label_color }};
    font-weight: {{ section.settings.stat_label_font_weight }};
    line-height: 1.3;
  }

  .vso-testimonials-05__testimonial {
    background-color: {{ section.settings.testimonial_bg_color }};
    border-radius: {{ section.settings.testimonial_border_radius }}px;
    padding: {{ section.settings.testimonial_padding }}px;
    {% if section.settings.enable_testimonial_shadow %}
      box-shadow: {{ section.settings.testimonial_shadow_color | color_modify: 'alpha', 0.15 }} 0px 4px 12px;
    {% endif %}
    border: {{ section.settings.testimonial_border_width }}px solid {{ section.settings.testimonial_border_color }};
    position: relative;
  }

  .vso-testimonials-05__stars {
    display: flex;
    gap: 2px;
    margin-bottom: {{ section.settings.stars_margin_bottom }}px;
  }

  .vso-testimonials-05__star {
    width: {{ section.settings.star_size_desktop }}px;
    height: {{ section.settings.star_size_desktop }}px;
    color: {{ section.settings.star_color }};
  }

  .vso-testimonials-05__testimonial-title {
    margin: 0 0 {{ section.settings.testimonial_title_margin_bottom }}px 0;
  }

  .vso-testimonials-05__testimonial-content {
    margin: 0 0 {{ section.settings.testimonial_content_margin_bottom }}px 0;
  }

  {% if section.settings.custom_testimonial_title_font %}
    .vso-testimonials-05__testimonial-title {
      font-size: {{ section.settings.testimonial_title_size_desktop }}px;
      color: {{ section.settings.testimonial_title_color }};
      font-weight: {{ section.settings.testimonial_title_font_weight }};
      line-height: {{ section.settings.testimonial_title_line_height }}%;
    }
  {% endif %}

  {% if section.settings.custom_testimonial_content_font %}
    .vso-testimonials-05__testimonial-content {
      font-size: {{ section.settings.testimonial_content_size_desktop }}px;
      color: {{ section.settings.testimonial_content_color }};
      font-weight: {{ section.settings.testimonial_content_font_weight }};
      line-height: {{ section.settings.testimonial_content_line_height }}%;
    }
  {% endif %}

  .vso-testimonials-05__author-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: 16px;
  }

  .vso-testimonials-05__author {
    display: flex;
    align-items: center;
    gap: {{ section.settings.author_gap }}px;
  }

  .vso-testimonials-05__author-avatar {
    width: {{ section.settings.avatar_size_desktop }}px;
    height: {{ section.settings.avatar_size_desktop }}px;
    border-radius: 50%;
    background-color: {{ section.settings.avatar_bg_color }};
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: {{ section.settings.avatar_text_size_desktop }}px;
    font-weight: 600;
    color: {{ section.settings.avatar_text_color }};
    flex-shrink: 0;
  }

  .vso-testimonials-05__author-info {
    flex: 1;
  }

  .vso-testimonials-05__author-name {
    margin: 0 0 2px 0;
    line-height: 1.2;
  }

  .vso-testimonials-05__author-location {
    margin: 0;
    line-height: 1.2;
  }

  {% if section.settings.custom_author_name_font %}
    .vso-testimonials-05__author-name {
      font-size: {{ section.settings.author_name_size_desktop }}px;
      color: {{ section.settings.author_name_color }};
      font-weight: {{ section.settings.author_name_font_weight }};
    }
  {% endif %}

  {% if section.settings.custom_author_location_font %}
    .vso-testimonials-05__author-location {
      font-size: {{ section.settings.author_location_size_desktop }}px;
      color: {{ section.settings.author_location_color }};
      font-weight: {{ section.settings.author_location_font_weight }};
    }
  {% endif %}

  .vso-testimonials-05__author-date {
    position: absolute;
    top: {{ section.settings.testimonial_padding }}px;
    right: {{ section.settings.testimonial_padding }}px;
    {% if section.settings.custom_author_date_font %}
      font-size: {{ section.settings.author_date_size_desktop }}px;
      color: {{ section.settings.author_date_color }};
      font-weight: {{ section.settings.author_date_font_weight }};
    {% endif %}
    line-height: 1.2;
    background-color: {{ section.settings.date_bg_color }};
    padding: {{ section.settings.date_padding_vertical }}px {{ section.settings.date_padding_horizontal }}px;
    border-radius: {{ section.settings.date_border_radius }}px;
    {% if section.settings.enable_date_shadow %}
      box-shadow: {{ section.settings.date_shadow_color | color_modify: 'alpha', 0.1 }} 0px 2px 4px;
    {% endif %}
  }

  .vso-testimonials-05__custom-pagination {
    display: flex;
    justify-content: center;
    gap: 8px;
    margin-top: 20px;
  }

  .vso-testimonials-05__pagination-bullet {
    width: 10px;
    height: 10px;
    background-color: {{ section.settings.pagination_bullet_color }};
    border-radius: 50%;
    cursor: pointer;
    opacity: 0.3;
    transition: all 0.3s ease;
  }

  .vso-testimonials-05__pagination-bullet.active {
    background-color: {{ section.settings.pagination_bullet_active_color }};
    opacity: 1;
  }

  .vso-testimonials-05__swiper .swiper-wrapper {
    overflow: visible !important;
  }

  .vso-testimonials-05__swiper .swiper-slide {
    overflow: visible !important;
  }

  .vso-testimonials-05__testimonials {
    flex: 1;
    max-width: 50%;
    position: relative;
    overflow: visible !important;
  }

  .vso-testimonials-05__swiper {
    width: 100%;
    overflow: visible !important;
    padding: 20px;
    margin: -20px;
  }

  .vso-testimonials-05__navigation-arrows {
    display: flex;
    gap: {{ section.settings.nav_arrow_spacing }}px;
  }

  .vso-testimonials-05__nav-prev,
  .vso-testimonials-05__nav-next {
    width: {{ section.settings.nav_arrow_size }}px;
    height: {{ section.settings.nav_arrow_size }}px;
    background-color: {{ section.settings.nav_arrow_bg_color }};
    border: {{ section.settings.nav_arrow_border_width }}px solid {{ section.settings.nav_arrow_border_color }};
    border-radius: 50%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .vso-testimonials-05__nav-prev svg,
  .vso-testimonials-05__nav-next svg {
    width: {{ section.settings.nav_arrow_size | times: 0.4 | round: 0 }}px;
    height: {{ section.settings.nav_arrow_size | times: 0.4 | round: 0 }}px;
    color: {{ section.settings.nav_arrow_icon_color }};
  }

  .vso-testimonials-05__nav-prev.swiper-button-disabled,
  .vso-testimonials-05__nav-next.swiper-button-disabled {
    opacity: 0.4;
    cursor: not-allowed;
  }

  @media screen and (min-width: 750px) {
    .vso-testimonials-05__container {
      padding: 0 {{ padding_horizontal }}px;
    }
  }

  @media screen and (max-width: 749px) {
    .vso-testimonials-05__container {
      flex-direction: column;
      gap: {{ mobile_gap }}px;
    }

    .vso-testimonials-05__content {
      max-width: 100%;
      text-align: {{ section.settings.content_alignment_mobile }};
    }

    .vso-testimonials-05__testimonials {
      max-width: 100%;
      overflow: visible !important;
    }

    {% if section.settings.custom_subtitle_font %}
      .vso-testimonials-05__subtitle {
        font-size: {{ section.settings.subtitle_size_mobile }}px;
      }
    {% endif %}

    {% if section.settings.custom_title_font %}
      .vso-testimonials-05__title {
        font-size: {{ section.settings.title_size_mobile }}px;
      }
    {% endif %}

    {% if section.settings.custom_description_font %}
      .vso-testimonials-05__description {
        font-size: {{ section.settings.description_size_mobile }}px;
      }
    {% endif %}

    .vso-testimonials-05__stats {
      justify-content: {{ section.settings.stats_alignment_mobile }};
      flex-wrap: wrap;
    }

    .vso-testimonials-05__pagination {
      justify-content: center;
    }

    .vso-testimonials-05__stat {
      text-align: {{ section.settings.stat_numbers_alignment_mobile }};
    }

    .vso-testimonials-05__stat-number {
      font-size: {{ section.settings.stat_number_size_mobile }}px;
    }

    .vso-testimonials-05__stat-label {
      font-size: {{ section.settings.stat_label_size_mobile }}px;
    }

    .vso-testimonials-05__star {
      width: {{ section.settings.star_size_mobile }}px;
      height: {{ section.settings.star_size_mobile }}px;
    }

    {% if section.settings.custom_testimonial_title_font %}
      .vso-testimonials-05__testimonial-title {
        font-size: {{ section.settings.testimonial_title_size_mobile }}px;
      }
    {% endif %}

    {% if section.settings.custom_testimonial_content_font %}
      .vso-testimonials-05__testimonial-content {
        font-size: {{ section.settings.testimonial_content_size_mobile }}px;
      }
    {% endif %}

    .vso-testimonials-05__author-avatar {
      width: {{ section.settings.avatar_size_mobile }}px;
      height: {{ section.settings.avatar_size_mobile }}px;
      font-size: {{ section.settings.avatar_text_size_mobile }}px;
    }

    {% if section.settings.custom_author_name_font %}
      .vso-testimonials-05__author-name {
        font-size: {{ section.settings.author_name_size_mobile }}px;
      }
    {% endif %}

    {% if section.settings.custom_author_location_font %}
      .vso-testimonials-05__author-location {
        font-size: {{ section.settings.author_location_size_mobile }}px;
      }
    {% endif %}

    {% if section.settings.custom_author_date_font %}
      .vso-testimonials-05__author-date {
        font-size: {{ section.settings.author_date_size_mobile }}px;
      }
    {% endif %}
  }

  .section-{{ section.id }} {
    padding-top: {{ section.settings.padding_top_desktop }}px;
    padding-bottom: {{ section.settings.padding_bottom_desktop }}px;
    margin-top: {{ section.settings.margin_top_desktop }}px;
    margin-bottom: {{ section.settings.margin_bottom_desktop }}px;
  }

  @media screen and (max-width: 749px) {
    .section-{{ section.id }} {
      padding-top: {{ section.settings.padding_top_mobile }}px;
      padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
      margin-top: {{ section.settings.margin_top_mobile }}px;
      margin-bottom: {{ section.settings.margin_bottom_mobile }}px;
    }
  }
{%- endstyle -%}

{% if section_full_width %}
  <style>
    #shopify-section-{{ section.id }}.section-full-width-enabled {
      width: 100vw !important;
      max-width: 100vw !important;
      margin-left: calc(50% - 50vw) !important;
      margin-right: calc(50% - 50vw) !important;
      left: 0 !important;
      right: 0 !important;
    }
    
    #shopify-section-{{ section.id }}.section-full-width-enabled .vso-testimonials-05 {
      max-width: none !important;
      margin: 0 !important;
    }
  </style>
{% endif %}

<style>
  #shopify-section-{{ section.id }} {
    {% if section.settings.background_style == 'gradient' %}
      background: linear-gradient(to bottom, {{ section.settings.gradient_start_color }}, {{ section.settings.gradient_end_color }});
    {% else %}
      background-color: {{ section.settings.background_color }};
    {% endif %}
    width: 100%;
  }
</style>

<div class="section-{{ section.id }} vso-node">
  <div class="vso-testimonials-05" id="testimonials-05-{{ section.id }}">
    <div class="vso-testimonials-05__container">
      <div class="vso-testimonials-05__content">
        {% if section.settings.subtitle != blank %}
          {% if section.settings.custom_subtitle_font %}
            <div class="vso-testimonials-05__subtitle">
              {% if section.settings.show_subtitle_dot %}
                <span class="vso-testimonials-05__subtitle-dot"></span>
              {% endif %}
              {{ section.settings.subtitle }}
            </div>
          {% else %}
            {%- assign subtitle_tag = section.settings.subtitle_as | default: 'p' -%}
            <{{ subtitle_tag }} class="vso-testimonials-05__subtitle">
              {{ section.settings.subtitle }}
            </{{ subtitle_tag }}>
          {% endif %}
        {% endif %}

        {% if section.settings.title != blank %}
          {% if section.settings.custom_title_font %}
            <div class="vso-testimonials-05__title">
              {{ section.settings.title }}
            </div>
          {% else %}
            {%- assign title_tag = section.settings.title_as | default: 'h2' -%}
            <{{ title_tag }} class="vso-testimonials-05__title">
              {{ section.settings.title }}
            </{{ title_tag }}>
          {% endif %}
        {% endif %}

        {% if section.settings.description != blank %}
          {% if section.settings.custom_description_font %}
            <div class="vso-testimonials-05__description">
              {{ section.settings.description }}
            </div>
          {% else %}
            {%- assign description_tag = section.settings.description_as | default: 'p' -%}
            <{{ description_tag }} class="vso-testimonials-05__description">
              {{ section.settings.description }}
            </{{ description_tag }}>
          {% endif %}
        {% endif %}

        {% if section.settings.show_stats %}
          <div class="vso-testimonials-05__stats">
            {% if section.settings.stat_1_number != blank %}
              <div class="vso-testimonials-05__stat">
                <div class="vso-testimonials-05__stat-number">
                  {{ section.settings.stat_1_number }}
                </div>
                <div class="vso-testimonials-05__stat-label">
                  {{ section.settings.stat_1_label }}
                </div>
              </div>
            {% endif %}

            {% if section.settings.stat_2_number != blank %}
              <div class="vso-testimonials-05__stat">
                <div class="vso-testimonials-05__stat-number">
                  {{ section.settings.stat_2_number }}
                </div>
                <div class="vso-testimonials-05__stat-label">
                  {{ section.settings.stat_2_label }}
                </div>
              </div>
            {% endif %}

            {% if section.settings.stat_3_number != blank %}
              <div class="vso-testimonials-05__stat">
                <div class="vso-testimonials-05__stat-number">
                  {{ section.settings.stat_3_number }}
                </div>
                <div class="vso-testimonials-05__stat-label">
                  {{ section.settings.stat_3_label }}
                </div>
              </div>
            {% endif %}
          </div>
        {% endif %}
      </div>

      {% if section.blocks.size > 0 %}
        <div class="vso-testimonials-05__testimonials">
          <div class="swiper vso-testimonials-05__swiper">
            <div class="swiper-wrapper">
              {% for block in section.blocks %}
                <div class="swiper-slide">
                  <div class="vso-testimonials-05__testimonial" {{ block.shopify_attributes }}>
                    {% if block.settings.show_stars %}
                      <div class="vso-testimonials-05__stars">
                        {%- liquid
                          assign rating = block.settings.star_rating
                          assign full_stars = rating | floor
                          assign half_star = rating | modulo: 1
                          assign empty_stars = 5 | minus: full_stars
                          if half_star >= 0.5
                            assign empty_stars = empty_stars | minus: 1
                          endif
                        -%}
                        {% for i in (1..full_stars) %}
                          <svg class="vso-testimonials-05__star" viewBox="0 0 24 24" fill="currentColor">
                            <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                          </svg>
                        {% endfor %}
                        {% if half_star >= 0.5 %}
                          <svg class="vso-testimonials-05__star" viewBox="0 0 24 24">
                            <defs>
                              <linearGradient id="half-testimonial-{{ block.id }}" x1="0%" y1="0%" x2="100%" y2="0%">
                                <stop offset="50%" style="stop-color:{{ section.settings.star_color }};stop-opacity:1" />
                                <stop offset="50%" style="stop-color:{{ section.settings.star_empty_color }};stop-opacity:1" />
                              </linearGradient>
                            </defs>
                            <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" fill="url(#half-testimonial-{{ block.id }})"/>
                          </svg>
                        {% endif %}
                        {% for i in (1..empty_stars) %}
                          <svg class="vso-testimonials-05__star" viewBox="0 0 24 24" fill="{{ section.settings.star_empty_color }}">
                            <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                          </svg>
                        {% endfor %}
                      </div>
                    {% endif %}

                    {% if block.settings.title != blank %}
                      {% if section.settings.custom_testimonial_title_font %}
                        <div class="vso-testimonials-05__testimonial-title">
                          {{ block.settings.title }}
                        </div>
                      {% else %}
                        {%- assign testimonial_title_tag = section.settings.testimonial_title_as | default: 'h3' -%}
                        <{{ testimonial_title_tag }} class="vso-testimonials-05__testimonial-title">
                          {{ block.settings.title }}
                        </{{ testimonial_title_tag }}>
                      {% endif %}
                    {% endif %}

                    {% if block.settings.content != blank %}
                      {% if section.settings.custom_testimonial_content_font %}
                        <div class="vso-testimonials-05__testimonial-content">
                          {{ block.settings.content }}
                        </div>
                      {% else %}
                        {%- assign testimonial_content_tag = section.settings.testimonial_content_as | default: 'p' -%}
                        <{{ testimonial_content_tag }} class="vso-testimonials-05__testimonial-content">
                          {{ block.settings.content }}
                        </{{ testimonial_content_tag }}>
                      {% endif %}
                    {% endif %}

                    {% if block.settings.author_date != blank %}
                      {% if section.settings.custom_author_date_font %}
                        <div class="vso-testimonials-05__author-date">
                          {{ block.settings.author_date }}
                        </div>
                      {% else %}
                        {%- assign author_date_tag = section.settings.author_date_as | default: 'p' -%}
                        <{{ author_date_tag }} class="vso-testimonials-05__author-date">
                          {{ block.settings.author_date }}
                        </{{ author_date_tag }}>
                      {% endif %}
                    {% endif %}

                    {% if block.settings.author_name != blank %}
                      <div class="vso-testimonials-05__author-row">
                        <div class="vso-testimonials-05__author">
                          {% assign first_initial = block.settings.author_name | slice: 0, 1 | upcase %}
                          <div class="vso-testimonials-05__author-avatar">
                            {{ first_initial }}
                          </div>
                          <div class="vso-testimonials-05__author-info">
                            {% if section.settings.custom_author_name_font %}
                              <div class="vso-testimonials-05__author-name">
                                {{ block.settings.author_name }}
                              </div>
                            {% else %}
                              {%- assign author_name_tag = section.settings.author_name_as | default: 'p' -%}
                              <{{ author_name_tag }} class="vso-testimonials-05__author-name">
                                {{ block.settings.author_name }}
                              </{{ author_name_tag }}>
                            {% endif %}
                            {% if block.settings.author_location != blank %}
                              {% if section.settings.custom_author_location_font %}
                                <div class="vso-testimonials-05__author-location">
                                  {{ block.settings.author_location }}
                                </div>
                              {% else %}
                                {%- assign author_location_tag = section.settings.author_location_as | default: 'p' -%}
                                <{{ author_location_tag }} class="vso-testimonials-05__author-location">
                                  {{ block.settings.author_location }}
                                </{{ author_location_tag }}>
                              {% endif %}
                            {% endif %}
                          </div>
                        </div>
                        
                        {% if section.blocks.size > 1 and section.settings.show_navigation %}
                          <div class="vso-testimonials-05__navigation-arrows">
                            <div class="vso-testimonials-05__nav-prev">
                              <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" style="transform: scaleX(-1);">
                                <path fill-rule="evenodd" clip-rule="evenodd" d="M8.29289 4.29289C8.68342 3.90237 9.31658 3.90237 9.70711 4.29289L16.7071 11.2929C17.0976 11.6834 17.0976 12.3166 16.7071 12.7071L9.70711 19.7071C9.31658 20.0976 8.68342 20.0976 8.29289 19.7071C7.90237 19.3166 7.90237 18.6834 8.29289 18.2929L14.5858 12L8.29289 5.70711C7.90237 5.31658 7.90237 4.68342 8.29289 4.29289Z" fill="currentColor"/>
                              </svg>
                            </div>
                            <div class="vso-testimonials-05__nav-next">
                              <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                                <path fill-rule="evenodd" clip-rule="evenodd" d="M8.29289 4.29289C8.68342 3.90237 9.31658 3.90237 9.70711 4.29289L16.7071 11.2929C17.0976 11.6834 17.0976 12.3166 16.7071 12.7071L9.70711 19.7071C9.31658 20.0976 8.68342 20.0976 8.29289 19.7071C7.90237 19.3166 7.90237 18.6834 8.29289 18.2929L14.5858 12L8.29289 5.70711C7.90237 5.31658 7.90237 4.68342 8.29289 4.29289Z" fill="currentColor"/>
                              </svg>
                            </div>
                          </div>
                        {% endif %}
                      </div>
                    {% endif %}

                    {% if section.blocks.size > 1 %}
                      <div class="vso-testimonials-05__custom-pagination">
                        {% for i in (1..section.blocks.size) %}
                          <div class="vso-testimonials-05__pagination-bullet" data-slide="{{ forloop.index0 }}"></div>
                        {% endfor %}
                      </div>
                    {% endif %}
                  </div>
                </div>
              {% endfor %}
            </div>
          </div>
        </div>
      {% endif %}
    </div>
  </div>
</div>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css" />
<script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js" defer></script>

<script defer>
document.addEventListener('DOMContentLoaded', function() {
  {% if section_full_width %}
    const section = document.getElementById('shopify-section-{{ section.id }}');
    if (section) {
      section.classList.add('section-full-width-enabled');
    }
  {% endif %}

  if (document.querySelector('.vso-testimonials-05__swiper')) {
    const swiperConfig = {
      loop: true,
      slidesPerView: 1,
      spaceBetween: 0,
      autoplay: {
        delay: {{ section.settings.autoplay_delay }},
        disableOnInteraction: false,
      },
      navigation: {
        nextEl: '.vso-testimonials-05__nav-next',
        prevEl: '.vso-testimonials-05__nav-prev',
      },
      speed: 600,
      effect: 'fade',
      fadeEffect: {
        crossFade: true
      },
      on: {
        slideChange: function() {
          updateCustomPagination(this.realIndex);
        }
      }
    };

    const testimonialSwiper = new Swiper('.vso-testimonials-05__swiper', swiperConfig);

    function updateCustomPagination(activeIndex) {
      const allPaginationContainers = document.querySelectorAll('.vso-testimonials-05__custom-pagination');
      
      allPaginationContainers.forEach(container => {
        const bullets = container.querySelectorAll('.vso-testimonials-05__pagination-bullet');
        bullets.forEach((bullet, index) => {
          bullet.classList.toggle('active', index === activeIndex);
        });
      });
    }

    const paginationBullets = document.querySelectorAll('.vso-testimonials-05__pagination-bullet');
    paginationBullets.forEach((bullet) => {
      bullet.addEventListener('click', () => {
        const slideIndex = parseInt(bullet.getAttribute('data-slide'));
        testimonialSwiper.slideToLoop(slideIndex);
        updateCustomPagination(slideIndex);
      });
    });

    updateCustomPagination(0);
  }
});
</script>

