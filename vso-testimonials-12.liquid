{% endcomment %}

{%- liquid
  assign text_alignment = 'left'
  assign blocks_alignment_desktop = section.settings.card_content_alignment_desktop
  assign blocks_alignment_mobile = section.settings.card_content_alignment_mobile

  if blocks_alignment_mobile == 'left'
    assign blocks_justify_mobile = 'flex-start'
  elsif blocks_alignment_mobile == 'center'
    assign blocks_justify_mobile = 'center'
  elsif blocks_alignment_mobile == 'right'
    assign blocks_justify_mobile = 'flex-end'
  endif
  assign desktop_blocks_gap = section.settings.desktop_blocks_gap
  assign mobile_blocks_gap = section.settings.mobile_blocks_gap
  assign block_padding = section.settings.block_padding
  assign header_blocks_gap = section.settings.header_blocks_gap
  assign header_blocks_gap_mobile = section.settings.header_blocks_gap_mobile
  assign stars_title_gap = section.settings.stars_title_gap
  assign full_width = section.settings.full_width
  assign content_width = section.settings.content_width
  assign cards_full_width_desktop = section.settings.cards_full_width_desktop
-%}

{%- style -%}
  {{ section.settings.title_font | font_face: font_display: 'swap' }}
  {{ section.settings.block_title_font | font_face: font_display: 'swap' }}
  {{ section.settings.block_description_font | font_face: font_display: 'swap' }}
  {{ section.settings.title_highlight_font | font_face: font_display: 'swap' }}

  {% if section.settings.custom_title_font %}
    #Testimonials-Cards-{{ section.id }} .vso-testimonials-cards__title {
      font-family: {{ section.settings.title_font.family }}, {{ section.settings.title_font.fallback_families }};
      font-style: {{ section.settings.title_font.style }};
    }
  {% endif %}

  {% if section.settings.custom_block_title_font %}
    #Testimonials-Cards-{{ section.id }} .vso-testimonials-cards__block-title {
      font-family: {{ section.settings.block_title_font.family }}, {{ section.settings.block_title_font.fallback_families }};
      font-style: {{ section.settings.block_title_font.style }};
      line-height: {{ section.settings.block_title_line_height }}%;
      font-size: {{ section.settings.block_title_size_desktop }}px;
      color: {{ section.settings.block_title_color }};
      font-weight: {{ section.settings.block_title_font_weight }};
    }
  {% endif %}

  {% if section.settings.custom_block_description_font %}
    #Testimonials-Cards-{{ section.id }} .vso-testimonials-cards__block-description {
      font-family: {{ section.settings.block_description_font.family }}, {{ section.settings.block_description_font.fallback_families }};
      font-style: {{ section.settings.block_description_font.style }};
      line-height: {{ section.settings.block_description_line_height }}%;
      font-size: {{ section.settings.block_description_size_desktop }}px;
      color: {{ section.settings.block_description_color }};
      font-weight: {{ section.settings.block_description_font_weight }};
    }
  {% endif %}

  .vso-testimonials-cards {
    padding: 0;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    position: relative;
  }

  .vso-testimonials-cards__header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: {{ header_blocks_gap }}px;
    width: 100%;
  }

  .vso-testimonials-cards__header-content {
    max-width: 60%;
    flex: 1;
  }

  .vso-testimonials-cards__rating {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    {% if section.settings.rating_badge_bg_enable %}
      background: {{ section.settings.rating_bg_color }};
    {% endif %}
    border-radius: 999px;
    {% if section.settings.rating_badge_bg_enable %}
      padding: {{ section.settings.rating_padding_vertical }}px {{ section.settings.rating_padding_horizontal }}px;
      {% if section.settings.rating_shadow_enable %}
        box-shadow: rgba(0, 0, 0, 0.08) 0px 4px 12px;
      {% endif %}
    {% endif %}
    margin-bottom: {{ section.settings.rating_bottom_spacing }}px;
    white-space: nowrap;
  }

  {% if section.settings.custom_rating_header_font %}
    #Testimonials-Cards-{{ section.id }} .vso-testimonials-cards__rating {
      color: {{ section.settings.rating_text_color }};
      font-size: {{ section.settings.rating_text_size }}px;
    }
  {% endif %}

  .vso-testimonials-cards__rating-stars {
    display: inline-flex;
    gap: {{ section.settings.star_gap }}px;
    font-size: {{ section.settings.star_size }}px;
  }

  .vso-testimonials-cards__rating-stars svg {
    width: {{ section.settings.rating_star_size }}px;
    height: {{ section.settings.rating_star_size }}px;
    color: {{ section.settings.rating_star_color }};
    display: block;
  }

  .vso-testimonials-cards__rating .star-empty svg {
    color: {{ section.settings.star_empty_color }};
  }

  .vso-testimonials-cards__rating-text { margin: 0; line-height: 1; }

  .vso-testimonials-cards__title {
    margin: 0;
    text-align: {{ text_alignment }};
  }

  {% if section.settings.custom_title_font %}
    #Testimonials-Cards-{{ section.id }} .vso-testimonials-cards__title {
      line-height: {{ section.settings.title_line_height }}%;
      font-size: {{ section.settings.title_size_desktop }}px;
      color: {{ section.settings.title_color }};
      font-weight: {{ section.settings.title_font_weight }};
    }
  {% endif %}
  #Testimonials-Cards-{{ section.id }} .vso-testimonials-cards__title .vso-testimonials-cards__title-highlight-{{ section.id }} {
    background: {{ section.settings.title_highlight_color }} !important;
    -webkit-background-clip: text !important;
    -webkit-text-fill-color: transparent !important;
    background-clip: text !important;
    color: transparent !important;
  }
  {% if section.settings.title_highlight_enable_custom %}
    #Testimonials-Cards-{{ section.id }} .vso-testimonials-cards__title .vso-testimonials-cards__title-highlight-{{ section.id }} {
      font-family: {{ section.settings.title_highlight_font.family }}, {{ section.settings.title_highlight_font.fallback_families }};
      font-style: {{ section.settings.title_highlight_font.style }};
      font-weight: {{ section.settings.title_highlight_font_weight }};
    }
  {% endif %}

  .vso-testimonials-cards__description {
    margin: 0;
    text-align: {{ text_alignment }};
    margin-top: {{ section.settings.description_top_spacing }}px;
    margin-bottom: {{ section.settings.description_bottom_spacing }}px;
  }

  {% if section.settings.custom_description_font %}
    #Testimonials-Cards-{{ section.id }} .vso-testimonials-cards__description {
      font-size: {{ section.settings.description_size_desktop }}px;
      color: {{ section.settings.description_color }};
      line-height: {{ section.settings.description_line_height }}%;
    }
  {% endif %}

  .vso-testimonials-cards__navigation {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: {{ section.settings.nav_arrow_gap }}px;
    margin-top: {{ section.settings.nav_arrow_top_spacing_mobile }}px;
  }

  @media screen and (min-width: 750px) {
    {% if section.settings.header_alignment_desktop == 'center' %}
      .vso-testimonials-cards__header {
        flex-direction: column;
        align-items: center;
        text-align: center;
      }
      .vso-testimonials-cards__header-content {
        max-width: 100%;
        text-align: center;
      }
      .vso-testimonials-cards__title,
      .vso-testimonials-cards__description {
        text-align: center;
      }
      .vso-testimonials-cards__navigation {
        position: static;
        width: 100%;
        justify-content: center;
        margin-top: {{ section.settings.nav_arrow_top_spacing_desktop_center }}px;
      }
    {% else %}
      .vso-testimonials-cards__navigation {
        position: absolute;
        top: 0;
        right: 0;
        margin-top: 0;
      }
    {% endif %}

    {% unless section.settings.show_navigation_desktop %}
      .vso-testimonials-cards__navigation { display: none; }
    {% endunless %}
  }

  @media screen and (max-width: 749px) {
    .vso-testimonials-cards__header {
      flex-direction: column;
      align-items: {% if section.settings.header_alignment_mobile == 'center' %}center{% else %}flex-start{% endif %};
      text-align: {% if section.settings.header_alignment_mobile == 'center' %}center{% else %}left{% endif %};
      margin-bottom: {{ header_blocks_gap_mobile }}px;
    }

    .vso-testimonials-cards__header-content {
      max-width: 100%;
      text-align: {% if section.settings.header_alignment_mobile == 'center' %}center{% else %}left{% endif %};
      margin-bottom: 0;
    }

    .vso-testimonials-cards__title {
      text-align: {% if section.settings.header_alignment_mobile == 'center' %}center{% else %}left{% endif %};
    }

    .vso-testimonials-cards__description {
      text-align: {% if section.settings.header_alignment_mobile == 'center' %}center{% else %}left{% endif %};
    }

    .vso-testimonials-cards__rating {
      white-space: normal;
      flex-wrap: wrap;
      justify-content: {% if section.settings.header_alignment_mobile == 'center' %}center{% else %}flex-start{% endif %};
    }

    .vso-testimonials-cards__navigation {
      position: static;
      margin-top: {{ section.settings.nav_arrow_top_spacing_mobile }}px;
      width: 100%;
      justify-content: center;
    }

    {% unless section.settings.show_navigation_mobile %}
      .vso-testimonials-cards__navigation {
        display: none;
      }
    {% endunless %}
  }

  .vso-testimonials-cards__swiper {
    width: 100%;
    padding: 0px !important;

    overflow: visible;
    position: relative;
    margin-top: {{ section.settings.cards_top_spacing_desktop }}px;
  }

  @media screen and (min-width: 750px) {
    .vso-testimonials-cards__swiper {
      overflow: visible;
    }

    {% if cards_full_width_desktop %}
      .vso-testimonials-cards__swiper {
        width: 100vw;
        margin-left: calc(-50vw + 50%);
        margin-right: calc(-50vw + 50%);
      }

      .section-{{ section.id }}-settings {
        overflow: visible;
      }

      .vso-testimonials-cards {
        overflow: visible;
      }

      .section-{{ section.id }} {
        overflow: visible;
      }

      #shopify-section-{{ section.id }} {
        overflow: visible;
      }
    {% endif %}
  }

  .vso-node { display: none; }
  .vso-node--v2 { display: block; }

  {% if section.settings.enable_equal_height %}
    .vso-testimonials-cards__swiper {
      height: auto;
    }

    .vso-testimonials-cards__swiper .swiper-wrapper {
      align-items: stretch;
      display: flex;
    }

    .vso-testimonials-cards__swiper .swiper-slide {
      height: auto;
      display: flex;
      flex-direction: column;
    }

    .vso-testimonials-cards__block {
      justify-content: flex-start;
    }

    .vso-testimonials-cards__author-container {
      margin-top: auto;
    }
  {% endif %}

  .vso-testimonials-cards__slide {
    {% if section.settings.cards_full_width_desktop %}
      width: auto;
      max-width: {{ section.settings.desktop_card_width }}px;
      min-width: 280px;
    {% else %}
      width: 100%;
      min-width: 0;
    {% endif %}
    {% if section.settings.enable_equal_height %}
      display: flex;
      height: 100%;
    {% endif %}
  }

  .vso-testimonials-cards__block {
    display: flex;
    flex-direction: column;
    align-items: {{ blocks_alignment_desktop }};
    padding: {{ block_padding }}px;
    background-color: {{ section.settings.block_background_color }};
    border-radius: {{ section.settings.block_border_radius }}px;
    border: {{ section.settings.block_border_width }}px solid {{ section.settings.block_border_color }};
    text-align: {{ blocks_alignment_desktop }};
    transition: transform 0.3s ease;
    overflow: hidden;
    {% if section.settings.enable_equal_height %}
      width: 100%;
      height: 100%;
    {% endif %}
  }

  .vso-testimonials-cards__block-header-content {
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: {{ blocks_alignment_desktop }};
    gap: {{ stars_title_gap }}px;
  }

  .vso-testimonials-cards__stars {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: {{ section.settings.star_gap }}px;
    font-size: {{ section.settings.star_size }}px;
    margin: 0;
    color: {{ section.settings.star_color }};
  }

  .vso-testimonials-cards__stars svg { display: block; }

  .vso-testimonials-cards__author-row {
    width: 100%;
    display: flex;
    align-items: center;
    gap: {{ section.settings.author_row_gap }}px;
    margin-bottom: {{ section.settings.author_row_margin_bottom }}px;
  }

  .vso-testimonials-cards__author-avatar {
    width: {{ section.settings.author_avatar_size }}px;
    height: {{ section.settings.author_avatar_size }}px;
    border-radius: 50%;
    overflow: hidden;
    flex-shrink: 0;
  }

  .vso-testimonials-cards__author-avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .vso-testimonials-cards__author-content {
    display: flex;
    flex-direction: column;
    gap: {{ section.settings.author_content_gap }}px;
    flex: 1;
  }

  .vso-testimonials-cards__meta-author {
    margin: 0;
    {% if section.settings.author_pill_enable %}
      background: {{ section.settings.author_pill_bg_color }};
      padding: 4px 10px;
      border-radius: 999px;
    {% else %}
      background: transparent;
      padding: 0;
    {% endif %}
    line-height: 1;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    width: fit-content;
  }
  {% if section.settings.custom_block_author_font %}
    #Testimonials-Cards-{{ section.id }} .vso-testimonials-cards__meta-author {
      font-size: {{ section.settings.block_author_size_desktop }}px;
      color: {{ section.settings.block_author_color }};
      font-weight: {{ section.settings.block_author_font_weight }};
    }
  {% endif %}

  .vso-testimonials-cards__meta-author svg {
    width: {{ section.settings.verified_icon_size }}px;
    height: {{ section.settings.verified_icon_size }}px;
  }

  .vso-testimonials-cards__block-title { width: 100%; margin: 0 0 {{ section.settings.block_title_margin_bottom }}px 0; }

  .vso-testimonials-cards__block-description { width: 100%; margin: 0; margin-top: {{ section.settings.block_description_margin_top }}px; position: relative; }

  #Testimonials-Cards-{{ section.id }} .vso-testimonials-cards__block-title {
    margin-bottom: {{ section.settings.block_title_margin_bottom }}px;
  }

  @media screen and (max-width: 749px) {
    .vso-testimonials-cards__swiper {
      padding: 15px 0px !important;
      overflow: visible;
      width: 100vw;
      margin-left: calc(-50vw + 50%);
      margin-right: calc(-50vw + 50%);

      padding-right: 20px !important;
      margin-top: {{ section.settings.cards_top_spacing_mobile }}px;
    }

    .vso-testimonials-cards__slide {
      width: calc(100vw - 70px);
      min-width: calc(100vw - 70px);
      max-width: calc(100vw - 70px);
    }

    .section-{{ section.id }}-settings {
      overflow: visible;
    }

    .vso-testimonials-cards {
      overflow: visible;
    }

    .section-{{ section.id }} {
      overflow: visible;
    }

    {% if section.settings.custom_title_font %}
      .vso-testimonials-cards__title {
        font-size: {{ section.settings.title_size_mobile }}px;
      }
    {% endif %}

    {% if section.settings.custom_block_title_font %}
      .vso-testimonials-cards__block-title { font-size: {{ section.settings.block_title_size_mobile }}px; }
    {% endif %}

    {% if section.settings.custom_block_description_font %}
      .vso-testimonials-cards__block-description { font-size: {{ section.settings.block_description_size_mobile }}px; }
    {% endif %}

    {% if section.settings.custom_block_author_font %}
      .vso-testimonials-cards__block-author { font-size: {{ section.settings.block_author_size_mobile }}px; }
    {% endif %}

    {% if section.settings.custom_description_font %}
      .vso-testimonials-cards__description {
        font-size: {{ section.settings.description_size_mobile }}px;
      }
    {% endif %}

    .vso-testimonials-cards__block {
      align-items: {{ blocks_alignment_mobile }};
      text-align: {{ blocks_alignment_mobile }};
    }

    .vso-testimonials-cards__block-header-content {
      align-items: {{ blocks_alignment_mobile }};
    }

    .vso-testimonials-cards__author-container {
      justify-content: {{ blocks_justify_mobile }};
    }

    .vso-testimonials-cards__author-info {
      {% if blocks_alignment_mobile == 'left' %}
        flex: 1;
      {% else %}
        flex: 0;
      {% endif %}
    }

  }

  .section-{{ section.id }} {
    padding-top: {{ section.settings.padding_top_desktop }}px;
    padding-bottom: {{ section.settings.padding_bottom_desktop }}px;
    margin-top: {{ section.settings.margin_top_desktop }}px;
    margin-bottom: {{ section.settings.margin_bottom_desktop }}px;
    padding-left: {{ section.settings.padding_horizontal_desktop }}px;
    padding-right: {{ section.settings.padding_horizontal_desktop }}px;
    width: 100%;
    max-width: 100%;
    box-sizing: border-box;
  }

  .section-{{ section.id }}-settings {
    margin: 0 auto;
    padding-left: 0;
    padding-right: 0;
  }

  @media screen and (max-width: 749px) {
    .section-{{ section.id }} {
      padding-top: {{ section.settings.padding_top_mobile }}px;
      padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
      margin-top: {{ section.settings.margin_top_mobile }}px;
      margin-bottom: {{ section.settings.margin_bottom_mobile }}px;
      padding-left: {{ section.settings.padding_horizontal_mobile }}px;
      padding-right: {{ section.settings.padding_horizontal_mobile }}px;
    }
  }

  .vso-testimonials-cards__nav-prev,
  .vso-testimonials-cards__nav-next {
    width: {{ section.settings.nav_arrow_size }}px;
    height: {{ section.settings.nav_arrow_size }}px;
    background-color: {{ section.settings.nav_arrow_bg_color }};
    border: {{ section.settings.nav_arrow_border_width }}px solid {{ section.settings.nav_arrow_border_color }};
    border-radius: 50%;
    cursor: pointer;
    transition: all 0.3s ease;
    display: flex;
    align-items: center;
    justify-content: center;
    {% if section.settings.nav_arrow_shadow_enable %}
      box-shadow: {{ section.settings.nav_arrow_shadow_color | color_modify: 'alpha', 0.24 }} 0px 3px 8px;
    {% endif %}
  }

  .vso-testimonials-cards__nav-prev svg,
  .vso-testimonials-cards__nav-next svg {
    width: {{ section.settings.nav_arrow_size | times: 0.4 | round: 0 }}px;
    height: {{ section.settings.nav_arrow_size | times: 0.4 | round: 0 }}px;
    color: {{ section.settings.nav_arrow_icon_color }};
    transition: color 0.3s ease;
  }

  .vso-testimonials-cards__nav-prev:hover,
  .vso-testimonials-cards__nav-next:hover {
    border-color: {{ section.settings.nav_arrow_border_color | color_darken: 10 }};
    {% if section.settings.nav_arrow_shadow_enable %}
      box-shadow: {{ section.settings.nav_arrow_shadow_color | color_modify: 'alpha', 0.32 }} 0px 4px 12px;
    {% endif %}
  }

  .vso-testimonials-cards__nav-prev:hover svg,
  .vso-testimonials-cards__nav-next:hover svg {
    color: {{ section.settings.nav_arrow_icon_color | color_darken: 20 }};
  }

  .vso-testimonials-cards__nav-prev.swiper-button-disabled,
  .vso-testimonials-cards__nav-next.swiper-button-disabled {
    opacity: 0.4;
    cursor: not-allowed;
  }
{%- endstyle -%}

<style>
#shopify-section-{{ section.id }} {
  background: {% if section.settings.section_bg_type == 'solid' %}{{ section.settings.section_bg_color }}{% else %}{{ section.settings.section_bg_gradient }}{% endif %};
  width: 100%;
  max-width: 100%;
  position: relative;
  padding-left: 0;
  padding-right: 0;
  overflow-x: hidden;
}

@media screen and (max-width: 749px) {
  #shopify-section-{{ section.id }} {
    overflow-x: hidden;
  }
}

#shopify-section-{{ section.id }}::before {
  content: "";
  position: absolute;
  left: 50%;
  top: 0;
  width: 100vw;
  height: 100%;
  transform: translateX(-50%);
  background: {% if section.settings.section_bg_type == 'solid' %}{{ section.settings.section_bg_color }}{% else %}{{ section.settings.section_bg_gradient }}{% endif %};
  z-index: -1;
}
</style>

{% unless full_width %}
<style>
  #shopify-section-{{ section.id }}.section--page-width {
    max-width: var(--page-width, 120rem);
    margin-left: auto;
    margin-right: auto;
    overflow-x: hidden;
    box-sizing: border-box;
  }
  .section-{{ section.id }}-settings {
    max-width: min({{ content_width }}rem, 100%);
    box-sizing: border-box;
  }
</style>
{% endunless %}

<div class="section-{{ section.id }} vso-node">
<div class="section-{{ section.id }}-settings">
  <div class="vso-testimonials-cards" id="Testimonials-Cards-{{ section.id }}">
    <div class="vso-testimonials-cards__header">
      <div class="vso-testimonials-cards__header-content">
        {% if section.settings.show_rating_header %}
          <div class="vso-testimonials-cards__rating">
            <span class="vso-testimonials-cards__rating-stars" aria-hidden="true">
              {%- liquid
                assign rating = section.settings.header_star_rating | default: 5
                assign full_stars = rating | floor
                assign half_star = rating | modulo: 1
                assign empty_stars = 5 | minus: full_stars
                if half_star >= 0.5
                  assign empty_stars = empty_stars | minus: 1
                endif
              -%}

              {% for i in (1..full_stars) %}
                <span class="star star-filled">
                  <svg viewBox="-2.4 -2.4 28.80 28.80" xmlns="http://www.w3.org/2000/svg" fill="none" width="1em" height="1em" style="display:block;">
                    <g id="SVGRepo_bgCarrier" stroke-width="0" transform="translate(1.2,1.2), scale(0.9)">
                      <rect x="-2.4" y="-2.4" width="28.80" height="28.80" rx="0" fill="{{ section.settings.star_background_color }}" strokewidth="0"></rect>
                    </g>
                    <g id="SVGRepo_tracerCarrier" stroke-linecap="round" stroke-linejoin="round"></g>
                    <g id="SVGRepo_iconCarrier">
                      <rect x="0" fill="none" width="24" height="24"></rect>
                      <g>
                        <path d="M12 2l2.582 6.953L22 9.257l-5.822 4.602L18.18 21 12 16.89 5.82 21l2.002-7.14L2 9.256l7.418-.304" fill="currentColor"></path>
                      </g>
                    </g>
                  </svg>
                </span>
              {% endfor %}

              {% if half_star >= 0.5 %}
                <span class="star star-half">
                  <svg viewBox="-2.4 -2.4 28.80 28.80" xmlns="http://www.w3.org/2000/svg" width="1em" height="1em">
                    <defs>
                      <linearGradient id="half-rating-{{ section.id }}" x1="0%" y1="0%" x2="100%" y2="0%">
                        <stop offset="50%" style="stop-color:{{ section.settings.star_background_color }};stop-opacity:1" />
                        <stop offset="50%" style="stop-color:{{ section.settings.star_empty_color }};stop-opacity:1" />
                      </linearGradient>
                    </defs>
