<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css" />
<script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js" defer></script>

<script defer>
document.addEventListener('DOMContentLoaded', function() {
const testimonialsSwiper = new Swiper('.vso-testimonials-cards__swiper', {
  loop: true,
  slidesPerView: {% if section.settings.cards_full_width_desktop %}'auto'{% else %}{% if section.settings.desktop_cards_per_view > 0 %}{{ section.settings.desktop_cards_per_view }}{% else %}3{% endif %}{% endif %},
  spaceBetween: {{ desktop_blocks_gap }},
  grabCursor: true,
  speed: 600,

  {% if section.settings.enable_equal_height %}
  watchSlidesProgress: true,
  {% endif %}

  navigation: {
    nextEl: '.vso-testimonials-cards__nav-next',
    prevEl: '.vso-testimonials-cards__nav-prev',
  },

  breakpoints: {
    0: {
      spaceBetween: {{ mobile_blocks_gap }},
      centeredSlides: false,
      slidesPerView: 'auto',
      slidesOffsetBefore: 0,
      slidesOffsetAfter: 60,
    },
    750: {
      spaceBetween: {{ desktop_blocks_gap }},
      centeredSlides: false,
      slidesPerView: {% if section.settings.cards_full_width_desktop %}'auto'{% else %}{% if section.settings.desktop_cards_per_view > 0 %}{{ section.settings.desktop_cards_per_view }}{% else %}3{% endif %}{% endif %},
    }
  }{% if section.settings.enable_equal_height %},

  on: {
    init: function() {
      setTimeout(() => {
        this.updateSlidesClasses();
        equalizeSlideHeights();
      }, 100);
    },
    slideChangeTransitionEnd: function() {
      equalizeSlideHeights();
    }
  }{% endif %}
});

{% if section.settings.enable_equal_height %}
function equalizeSlideHeights() {
  const slides = document.querySelectorAll('.vso-testimonials-cards__swiper .swiper-slide');
  const blocks = document.querySelectorAll('.vso-testimonials-cards__swiper .vso-testimonials-cards__block');

  if (slides.length === 0 || blocks.length === 0) return;

  blocks.forEach(block => {
    block.style.height = 'auto';
  });

  let maxHeight = 0;
  blocks.forEach(block => {
    const height = block.offsetHeight;
    if (height > maxHeight) {
      maxHeight = height;
    }
  });

  blocks.forEach(block => {
    block.style.height = maxHeight + 'px';
  });
}

window.addEventListener('resize', function() {
  setTimeout(equalizeSlideHeights, 100);
});
{% endif %}
});
</script>

<script>
(function(){
const sectionId = '{{ section.id }}';
const outer = document.getElementById('shopify-section-' + sectionId);
if(outer){
  outer.classList.toggle('section--full-width', {{ full_width | json }});
  outer.classList.toggle('section--page-width', !{{ full_width | json }});

  outer.style.overflowX = 'hidden';

  outer.style.maxWidth = '100%';
}
})();
</script>

