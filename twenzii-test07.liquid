<script>
(function() {
  function initInfiniteScroll() {
    const scrollContainers = document.querySelectorAll('.vso-testimonials-07__scroll-container');

    scrollContainers.forEach(function(container) {
      if (window.innerWidth <= 768) {
        // Get all cards in the container
        const cards = container.querySelectorAll('.vso-testimonials-07__testimonial-card');
        const totalCards = cards.length;

        if (totalCards < 2) return; // Need at least 2 cards

        const halfCards = Math.floor(totalCards / 2);

        // Get the computed gap value once
        const computedStyle = window.getComputedStyle(container);
        const gap = parseFloat(computedStyle.gap) || 0;

        // Calculate the exact position where the first duplicate card starts
        // This is more accurate than manually calculating widths
        let scrollWidth = 0;

        // Method 1: Use getBoundingClientRect for precise positioning
        const firstCardRect = cards[0].getBoundingClientRect();
        const duplicateCardRect = cards[halfCards].getBoundingClientRect();
        scrollWidth = duplicateCardRect.left - firstCardRect.left;

        // Fallback method if cards are not visible
        if (scrollWidth <= 0) {
          for (let i = 0; i < halfCards; i++) {
            const cardStyle = window.getComputedStyle(cards[i]);
            const cardWidth = cards[i].offsetWidth +
                            parseFloat(cardStyle.marginLeft || 0) +
                            parseFloat(cardStyle.marginRight || 0);
            scrollWidth += cardWidth;
            // Add gap between cards
            if (i < halfCards) {
              scrollWidth += gap;
            }
          }
        }

        // Set CSS variables with precise width
        container.style.setProperty('--scroll-width', scrollWidth + 'px');

        // Calculate duration based on scroll width to maintain consistent speed
        const baseSpeed = {{ scroll_speed_mobile }};
        container.style.setProperty('--scroll-duration', baseSpeed + 's');

        // Start the animation
        requestAnimationFrame(function() {
          container.classList.add('scrolling');
        });
      } else {
        // Remove mobile-specific classes and properties on desktop
        container.classList.remove('scrolling');
        container.style.removeProperty('--scroll-width');
        container.style.removeProperty('--scroll-duration');
      }
    });
  }

  // Initialize on page load
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', function() {
      setTimeout(initInfiniteScroll, 100);
    });
  } else {
    setTimeout(initInfiniteScroll, 100);
  }

  // Reinitialize on window resize (debounced)
  let resizeTimer;
  window.addEventListener('resize', function() {
    clearTimeout(resizeTimer);
    resizeTimer = setTimeout(function() {
      const scrollContainers = document.querySelectorAll('.vso-testimonials-07__scroll-container');
      scrollContainers.forEach(function(container) {
        container.classList.remove('scrolling');
        container.style.removeProperty('--scroll-width');
        container.style.removeProperty('--scroll-duration');
      });
      setTimeout(initInfiniteScroll, 100);
    }, 250);
  });
})();
</script>

