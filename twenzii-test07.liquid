{%- liquid
  assign bg_color = section.settings.color_background
  assign scroll_speed_desktop = section.settings.scroll_speed_desktop
  assign scroll_speed_mobile = section.settings.scroll_speed_mobile
  assign card_max_width = section.settings.card_max_width
  assign card_max_width_mobile = section.settings.card_max_width_mobile
  assign card_gap = section.settings.card_gap
  assign layout = section.settings.layout
-%}

<style>
  .vso-testimonials-07__wrapper {
    background-color: {{ bg_color }};
    padding: {{ section.settings.padding_top_desktop }}px 0 {{ section.settings.padding_bottom_desktop }}px;
  }

  .vso-testimonials-07__container {
    max-width: {% unless section.settings.section_full_width %}{{ section.settings.section_max_width }}rem{% else %}100%{% endunless %};
    margin: 0 auto;
    padding: 0 {{ section.settings.padding_horizontal }}rem;
  }

  .vso-testimonials-07__header {
    text-align: center;
    margin-bottom: {{ section.settings.content_testimonial_gap }}px;
    max-width: {{ section.settings.text_container_max_width }}px;
    margin-left: auto;
    margin-right: auto;
  }

  .vso-testimonials-07__header--horizontal {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: {{ section.settings.content_testimonial_gap }}px;
    align-items: center;
    text-align: left;
    margin-bottom: {{ section.settings.content_testimonial_gap }}px;
    max-width: none;
  }

  .vso-testimonials-07__header--horizontal .vso-testimonials-07__subtitle {
    justify-content: flex-start;
  }

  .vso-testimonials-07__subtitle {
    margin: 0 0 {{ section.settings.subtitle_margin_bottom }}px 0;
    font-size: {{ section.settings.subtitle_size_desktop }}px;
    color: {{ section.settings.subtitle_color }};
    font-weight: {{ section.settings.subtitle_font_weight }};
    line-height: {{ section.settings.subtitle_line_height }}%;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    background-color: {{ section.settings.subtitle_bg_color }};
    padding: {{ section.settings.subtitle_padding_vertical }}px {{ section.settings.subtitle_padding_horizontal }}px;
    border-radius: {{ section.settings.subtitle_border_radius }}px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: {{ section.settings.subtitle_dot_spacing }}px;
  }

  .vso-testimonials-07__subtitle-dot {
    width: {{ section.settings.subtitle_dot_size }}px;
    height: {{ section.settings.subtitle_dot_size }}px;
    background-color: {{ section.settings.subtitle_dot_color }};
    border-radius: 50%;
    flex-shrink: 0;
    display: inline-block;
    {% if section.settings.enable_subtitle_dot_pulse %}
      -webkit-animation: vso-pulse-{{ section.id }} 2s infinite;
      animation: vso-pulse-{{ section.id }} 2s infinite;
    {% endif %}
  }

  .vso-node {
    display: none;
  }
  .vso-node--v2 {
    display: block;
  }

  {% if section.settings.enable_subtitle_dot_pulse %}
    @-webkit-keyframes vso-pulse-{{ section.id }} {
      0% {
        opacity: 1;
        transform: scale(1);
      }
      50% {
        opacity: 0.4;
        transform: scale(1.5);
      }
      100% {
        opacity: 1;
        transform: scale(1);
      }
    }
    @keyframes vso-pulse-{{ section.id }} {
      0% {
        opacity: 1;
        transform: scale(1);
      }
      50% {
        opacity: 0.4;
        transform: scale(1.5);
      }
      100% {
        opacity: 1;
        transform: scale(1);
      }
    }
  {% endif %}

  .vso-testimonials-07__title {
    margin: 0 0 {{ section.settings.title_margin_bottom }}px 0;
    font-size: {{ section.settings.title_size_desktop }}px;
    color: {{ section.settings.title_color }};
    font-weight: {{ section.settings.title_font_weight }};
    line-height: {{ section.settings.title_line_height }}%;
  }

  .vso-testimonials-07__description {
    margin: 0 0 {{ section.settings.description_margin_bottom }}px 0;
    font-size: {{ section.settings.description_size_desktop }}px;
    color: {{ section.settings.description_color }};
    font-weight: {{ section.settings.description_font_weight }};
    line-height: {{ section.settings.description_line_height }}%;
  }

  .vso-testimonials-07__stats {
    display: flex;
    justify-content: {{ section.settings.stats_alignment_desktop }};
    gap: {{ section.settings.stats_gap }}px;
    margin-top: {{ section.settings.stats_margin_top }}px;
  }

  .vso-testimonials-07__stat {
    text-align: {{ section.settings.stat_numbers_alignment_desktop }};
    position: relative;
  }

  .vso-testimonials-07__stat:not(:last-child)::after {
    content: '';
    position: absolute;
    right: calc(-{{ section.settings.stats_gap }}px / 2);
    top: 50%;
    transform: translateY(-50%);
    width: 1px;
    height: 40px;
    background-color: {{ section.settings.stat_divider_color }};
  }

  .vso-testimonials-07__stat-number {
    margin: 0 0 4px 0;
    font-size: {{ section.settings.stat_number_size_desktop }}px;
    color: {{ section.settings.stat_number_color }};
    font-weight: {{ section.settings.stat_number_font_weight }};
    line-height: 1.2;
  }

  .vso-testimonials-07__stat-label {
    margin: 0;
    font-size: {{ section.settings.stat_label_size_desktop }}px;
    color: {{ section.settings.stat_label_color }};
    font-weight: {{ section.settings.stat_label_font_weight }};
    line-height: 1.3;
  }

  .vso-testimonials-07__testimonials-wrapper {
    overflow: hidden;
    position: relative;
    padding: 20px;
    margin: -20px;
  }

  .vso-testimonials-07__testimonials-wrapper::before,
  .vso-testimonials-07__testimonials-wrapper::after {
    content: '';
    position: absolute;
    top: 0;
    bottom: 0;
    width: 100px;
    z-index: 2;
    pointer-events: none;
  }

  .vso-testimonials-07__testimonials-wrapper::before {
    left: 0;
    background: linear-gradient(to right, {{ bg_color }}, transparent);
  }

  .vso-testimonials-07__testimonials-wrapper::after {
    right: 0;
    background: linear-gradient(to left, {{ bg_color }}, transparent);
  }

  .vso-testimonials-07__scroll-container {
    display: flex;
    align-items: flex-start;
    gap: {{ card_gap }}px;
    animation: vso-scroll-{{ section.id }} {{ scroll_speed_desktop }}s linear infinite;
    will-change: transform;
    flex-wrap: nowrap;
  }

  .vso-testimonials-07__scroll-container:hover {
    animation-play-state: paused;
  }

  .vso-testimonials-07__testimonial-card {
    background-color: {{ section.settings.testimonial_bg_color }};
    border-radius: {{ section.settings.testimonial_border_radius }}px;
    padding: {{ section.settings.testimonial_padding }}px;
    {% if section.settings.enable_testimonial_shadow %}
      box-shadow: {{ section.settings.testimonial_shadow_color | color_modify: 'alpha', 0.15 }} 0px 4px 12px;
    {% endif %}
    border: {{ section.settings.testimonial_border_width }}px solid {{ section.settings.testimonial_border_color }};
    flex-shrink: 0;
    width: {{ card_max_width }}px;
    position: relative;
  }

  .vso-testimonials-07__stars {
    display: flex;
    flex-direction: row;
    gap: {{ section.settings.star_gap }}px;
    font-size: {{ section.settings.star_size_desktop }}px;
    margin: 0 0 {{ section.settings.stars_margin_bottom }}px 0;
    margin-top: -12px;
    color: {{ section.settings.star_color }};
  }

  .vso-testimonials-07__testimonial-title {
    margin: 0 0 {{ section.settings.testimonial_title_margin_bottom }}px 0;
    font-size: {{ section.settings.testimonial_title_size_desktop }}px;
    color: {{ section.settings.testimonial_title_color }};
    font-weight: {{ section.settings.testimonial_title_font_weight }};
    line-height: {{ section.settings.testimonial_title_line_height }}%;
  }

  .vso-testimonials-07__testimonial-text {
    margin: 0 0 {{ section.settings.testimonial_content_margin_bottom }}px 0;
    font-size: {{ section.settings.testimonial_content_size_desktop }}px;
    color: {{ section.settings.testimonial_content_color }};
    font-weight: {{ section.settings.testimonial_content_font_weight }};
    line-height: {{ section.settings.testimonial_content_line_height }}%;
  }

  .vso-testimonials-07__author {
    display: flex;
    align-items: center;
    gap: {{ section.settings.author_gap }}px;
    margin-top: 16px;
  }

  .vso-testimonials-07__author-avatar {
    width: {{ section.settings.avatar_size_desktop }}px;
    height: {{ section.settings.avatar_size_desktop }}px;
    border-radius: 50%;
    background-color: {{ section.settings.avatar_bg_color }};
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: {{ section.settings.avatar_text_size_desktop }}px;
    font-weight: 600;
    color: {{ section.settings.avatar_text_color }};
    flex-shrink: 0;
  }

  .vso-testimonials-07__author-avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 50%;
  }

  .vso-testimonials-07__author-info {
    flex: 1;
  }

  .vso-testimonials-07__author-name {
    margin: 0 0 2px 0;
    font-size: {{ section.settings.author_name_size_desktop }}px;
    color: {{ section.settings.author_name_color }};
    font-weight: {{ section.settings.author_name_font_weight }};
    line-height: 1.2;
  }

  .vso-testimonials-07__author-location {
    margin: 0;
    font-size: {{ section.settings.author_location_size_desktop }}px;
    color: {{ section.settings.author_location_color }};
    font-weight: {{ section.settings.author_location_font_weight }};
    line-height: 1.2;
  }

  .vso-testimonials-07__author-date {
    position: absolute;
    top: {{ section.settings.testimonial_padding }}px;
    right: {{ section.settings.testimonial_padding }}px;
    font-size: {{ section.settings.author_date_size_desktop }}px;
    color: {{ section.settings.author_date_color }};
    font-weight: {{ section.settings.author_date_font_weight }};
    background-color: {{ section.settings.date_bg_color }};
    padding: {{ section.settings.date_padding_vertical }}px {{ section.settings.date_padding_horizontal }}px;
    border-radius: {{ section.settings.date_border_radius }}px;
    line-height: 1;
  }

  @keyframes vso-scroll-{{ section.id }} {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(calc(-1 * var(--scroll-width, 50%)));
    }
  }

  @media (max-width: 768px) {
    .vso-testimonials-07__scroll-container {
      animation: none;
    }

    .vso-testimonials-07__scroll-container.scrolling {
      animation: vso-scroll-mobile-{{ section.id }} linear infinite;
      animation-duration: var(--scroll-duration, {{ scroll_speed_mobile }}s);
    }

    .vso-testimonials-07__testimonials-wrapper {
      margin: -20px 0;
      padding: 20px 0;
      overflow: hidden;
    }
  }

  @keyframes vso-scroll-mobile-{{ section.id }} {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(calc(-1 * var(--scroll-width)));
    }
  }

    .vso-testimonials-07__wrapper {
      padding: {{ section.settings.padding_top_mobile }}px 0 {{ section.settings.padding_bottom_mobile }}px;
    }

    .vso-testimonials-07__container {
      padding: 0 {{ section.settings.padding_horizontal_mobile }}rem;
    }

    .vso-testimonials-07__subtitle {
      font-size: {{ section.settings.subtitle_size_mobile }}px;
    }

    .vso-testimonials-07__title {
      font-size: {{ section.settings.title_size_mobile }}px;
    }

    .vso-testimonials-07__description {
      font-size: {{ section.settings.description_size_mobile }}px;
    }

    .vso-testimonials-07__stats {
      justify-content: {{ section.settings.stats_alignment_mobile }};
      flex-wrap: nowrap;
    }

    .vso-testimonials-07__stat {
      text-align: {{ section.settings.stat_numbers_alignment_mobile }};
      flex: 1;
      min-width: 0;
    }

    .vso-testimonials-07__stat-number {
      font-size: {{ section.settings.stat_number_size_mobile }}px;
    }

    .vso-testimonials-07__stat-label {
      font-size: {{ section.settings.stat_label_size_mobile }}px;
    }

    .vso-testimonials-07__testimonial-card {
      width: {{ card_max_width_mobile }}px;
    }

    .vso-testimonials-07__stars {
      font-size: {{ section.settings.star_size_mobile }}px;
    }

    .vso-testimonials-07__testimonial-title {
      font-size: {{ section.settings.testimonial_title_size_mobile }}px;
    }

    .vso-testimonials-07__testimonial-text {
      font-size: {{ section.settings.testimonial_content_size_mobile }}px;
    }

    .vso-testimonials-07__author-avatar {
      width: {{ section.settings.avatar_size_mobile }}px;
      height: {{ section.settings.avatar_size_mobile }}px;
      font-size: {{ section.settings.avatar_text_size_mobile }}px;
    }

    .vso-testimonials-07__author-name {
      font-size: {{ section.settings.author_name_size_mobile }}px;
    }

    .vso-testimonials-07__author-location {
      font-size: {{ section.settings.author_location_size_mobile }}px;
    }

    .vso-testimonials-07__author-date {
      font-size: {{ section.settings.author_date_size_mobile }}px;
    }

    .vso-testimonials-07__header--horizontal {
      grid-template-columns: 1fr;
      gap: 40px;
      text-align: center;
    }

    .vso-testimonials-07__header--horizontal .vso-testimonials-07__subtitle {
      justify-content: center;
    }
  }
</style>

<div class="vso-testimonials-07__wrapper vso-node">
  <div class="vso-testimonials-07__container">
    {%- if layout == 'horizontal' -%}
      <div class="vso-testimonials-07__header vso-testimonials-07__header--horizontal">
        <div class="vso-testimonials-07__text-content">
          {%- if section.settings.subtitle != blank -%}
            <div class="vso-testimonials-07__subtitle">
              {%- if section.settings.show_subtitle_dot -%}
                <span class="vso-testimonials-07__subtitle-dot"></span>
              {%- endif -%}
              {{ section.settings.subtitle }}
            </div>
          {%- endif -%}

          {%- if section.settings.title != blank -%}
            <h2 class="vso-testimonials-07__title">{{ section.settings.title }}</h2>
          {%- endif -%}

          {%- if section.settings.description != blank -%}
            <div class="vso-testimonials-07__description">{{ section.settings.description }}</div>
          {%- endif -%}

          {%- if section.settings.show_stats -%}
            <div class="vso-testimonials-07__stats">
              {%- if section.settings.stat_1_number != blank -%}
                <div class="vso-testimonials-07__stat">
                  <div class="vso-testimonials-07__stat-number">{{ section.settings.stat_1_number }}</div>
                  <div class="vso-testimonials-07__stat-label">{{ section.settings.stat_1_label }}</div>
                </div>
              {%- endif -%}

              {%- if section.settings.stat_2_number != blank -%}
                <div class="vso-testimonials-07__stat">
                  <div class="vso-testimonials-07__stat-number">{{ section.settings.stat_2_number }}</div>
                  <div class="vso-testimonials-07__stat-label">{{ section.settings.stat_2_label }}</div>
                </div>
              {%- endif -%}

              {%- if section.settings.stat_3_number != blank -%}
                <div class="vso-testimonials-07__stat">
                  <div class="vso-testimonials-07__stat-number">{{ section.settings.stat_3_number }}</div>
                  <div class="vso-testimonials-07__stat-label">{{ section.settings.stat_3_label }}</div>
                </div>
              {%- endif -%}
            </div>
          {%- endif -%}
        </div>

        <div class="vso-testimonials-07__testimonials-wrapper">
          <div class="vso-testimonials-07__scroll-container">
            {%- for block in section.blocks -%}
              {%- if block.type == 'testimonial' -%}
                <div class="vso-testimonials-07__testimonial-card">
                  {%- if block.settings.show_stars -%}
                    <div class="vso-testimonials-07__stars">
                      {%- liquid
                        assign rating = block.settings.star_rating
                        assign full_stars = rating | floor
                        assign half_star = rating | modulo: 1
                        assign empty_stars = 5 | minus: full_stars
                        if half_star >= 0.5
                          assign empty_stars = empty_stars | minus: 1
                        endif
                      -%}
                      
                      {% for i in (1..full_stars) %}
                        {% case section.settings.star_icon %}
                          {% when 'star1' %}
                            <span class="star star-filled">
                              <svg viewBox="-2.4 -2.4 28.80 28.80" xmlns="http://www.w3.org/2000/svg" fill="currentColor" width="1em" height="1em"><g stroke-width="0" transform="translate(1.2,1.2), scale(0.9)"><rect x="-2.4" y="-2.4" width="28.80" height="28.80" rx="2.88" fill="{{ section.settings.star_bg_color }}"></rect></g><g> <rect x="0" fill="none" width="24" height="24"></rect> <g> <path d="M12 2l2.582 6.953L22 9.257l-5.822 4.602L18.18 21 12 16.89 5.82 21l2.002-7.14L2 9.256l7.418-.304"></path> </g> </g></svg>
                            </span>
                          {% when 'star2' %}
                            <span class="star star-filled">
                              <svg width="1em" height="1em" viewBox="0 0 425.305 425.305" fill="currentColor" xmlns="http://www.w3.org/2000/svg"><g><g><g><path style="fill:{{ section.settings.star_bg_color }};" d="M47.781,0v329.743h103.74l61.132,95.562l61.142-95.562h103.73V0H47.781z"></path><path style="fill:currentColor;" d="M267.16,179.732 l12.858,75.045l-67.375-35.427l-67.385,35.427l12.867-75.045l-54.518-53.14l75.338-10.952l33.697-68.274l33.688,68.274 l75.338,10.952L267.16,179.732z"></path></g></g></g></svg>
                            </span>
                          {% when 'star3' %}
                            <span class="star star-filled">
                              <svg width="1em" height="1em" viewBox="0 0 1200 1200" fill="currentColor" xmlns="http://www.w3.org/2000/svg"><circle cx="600" cy="600" r="600" fill="{{ section.settings.star_bg_color }}"/><path d="M603.955,209.912l94.556,295.239l309.889,6.958L756.812,693.164l89.136,296.924 L595.972,806.763L341.162,983.35l97.119-294.434l-246.68-187.793l310.034,1.392L603.955,209.912L603.955,209.912z" fill="currentColor"></path></svg>
                            </span>
                          {% else %}
                            <span class="star star-filled">★</span>
                        {% endcase %}
                      {% endfor %}
                      
                      {% if half_star >= 0.5 %}
                        {% case section.settings.star_icon %}
                          {% when 'star1' %}
                            <span class="star star-half">
                              <svg viewBox="-2.4 -2.4 28.80 28.80" xmlns="http://www.w3.org/2000/svg" width="1em" height="1em">
                                <defs>
                                  <linearGradient id="half-bg-07-{{ block.id }}" x1="0%" y1="0%" x2="100%" y2="0%">
                                    <stop offset="50%" style="stop-color:{{ section.settings.star_bg_color }};stop-opacity:1" />
                                    <stop offset="50%" style="stop-color:{{ section.settings.star_empty_color }};stop-opacity:1" />
                                  </linearGradient>
                                </defs>
                                <g stroke-width="0" transform="translate(1.2,1.2), scale(0.9)"><rect x="-2.4" y="-2.4" width="28.80" height="28.80" rx="2.88" fill="url(#half-bg-07-{{ block.id }})"></rect></g>
                                <g> <rect x="0" fill="none" width="24" height="24"></rect> <g> <path d="M12 2l2.582 6.953L22 9.257l-5.822 4.602L18.18 21 12 16.89 5.82 21l2.002-7.14L2 9.256l7.418-.304" fill="currentColor"></path> </g> </g>
                              </svg>
                            </span>
                          {% when 'star2' %}
                            <span class="star star-half">
                              <svg width="1em" height="1em" viewBox="0 0 425.305 425.305" xmlns="http://www.w3.org/2000/svg">
                                <defs>
                                  <linearGradient id="half-bg-07-{{ block.id }}" x1="0%" y1="0%" x2="100%" y2="0%">
                                    <stop offset="50%" style="stop-color:{{ section.settings.star_bg_color }};stop-opacity:1" />
                                    <stop offset="50%" style="stop-color:{{ section.settings.star_empty_color }};stop-opacity:1" />
                                  </linearGradient>
                                </defs>
                                <g><g><g><path style="fill:url(#half-bg-07-{{ block.id }});" d="M47.781,0v329.743h103.74l61.132,95.562l61.142-95.562h103.73V0H47.781z"></path><path style="fill:currentColor;" d="M267.16,179.732 l12.858,75.045l-67.375-35.427l-67.385,35.427l12.867-75.045l-54.518-53.14l75.338-10.952l33.697-68.274l33.688,68.274 l75.338,10.952L267.16,179.732z"></path></g></g></g>
                              </svg>
                            </span>
                          {% when 'star3' %}
                            <span class="star star-half">
                              <svg width="1em" height="1em" viewBox="0 0 1200 1200" xmlns="http://www.w3.org/2000/svg">
                                <defs>
                                  <linearGradient id="half-bg-07-{{ block.id }}" x1="0%" y1="0%" x2="100%" y2="0%">
                                    <stop offset="50%" style="stop-color:{{ section.settings.star_bg_color }};stop-opacity:1" />
                                    <stop offset="50%" style="stop-color:{{ section.settings.star_empty_color }};stop-opacity:1" />
                                  </linearGradient>
                                </defs>
                                <circle cx="600" cy="600" r="600" fill="url(#half-bg-07-{{ block.id }})"/>
                                <path d="M603.955,209.912l94.556,295.239l309.889,6.958L756.812,693.164l89.136,296.924 L595.972,806.763L341.162,983.35l97.119-294.434l-246.68-187.793l310.034,1.392L603.955,209.912L603.955,209.912z" fill="currentColor"></path>
                              </svg>
                            </span>
                          {% else %}
                            <span class="star star-half" style="background: linear-gradient(to right, {{ section.settings.star_bg_color }} 50%, {{ section.settings.star_empty_color }} 50%); color: {{ section.settings.star_color }};">★</span>
                        {% endcase %}
                      {% endif %}
                      
                      {% for i in (1..empty_stars) %}
                        {% case section.settings.star_icon %}
                          {% when 'star1' %}
                            <span class="star star-empty">
                              <svg viewBox="-2.4 -2.4 28.80 28.80" xmlns="http://www.w3.org/2000/svg" fill="{{ section.settings.star_empty_color }}" width="1em" height="1em"><g stroke-width="0" transform="translate(1.2,1.2), scale(0.9)"><rect x="-2.4" y="-2.4" width="28.80" height="28.80" rx="2.88" fill="{{ section.settings.star_bg_color }}"></rect></g><g> <rect x="0" fill="none" width="24" height="24"></rect> <g> <path d="M12 2l2.582 6.953L22 9.257l-5.822 4.602L18.18 21 12 16.89 5.82 21l2.002-7.14L2 9.256l7.418-.304"></path> </g> </g></svg>
                            </span>
                          {% when 'star2' %}
