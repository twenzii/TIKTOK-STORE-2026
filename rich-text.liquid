{% liquid
  assign section_width = ''
  if section.settings.section_width == 'fix_width'
    assign section_width = ' container'
  elsif section.settings.section_width == 'expand_full_width'
    assign section_width = ' full-width px-20'
  else
    assign section_width = ' full-width-gap'
  endif
  assign tb_top_spacing = ''
  if section.settings.padding_top > settings.vertical_space_tablet
    assign tb_top_spacing = ' top-tb'
  endif
  assign tb_bottom_spacing = ''
  if section.settings.padding_bottom > settings.vertical_space_tablet
    assign tb_bottom_spacing = ' bottom-tb'
  endif

  assign mb_top_spacing = ''
  if section.settings.padding_top > settings.vertical_space_mobile
    assign mb_top_spacing = ' top-mb'
  endif
  assign mb_bottom_spacing = ''
  if section.settings.padding_bottom > settings.vertical_space_mobile
    assign mb_bottom_spacing = ' bottom-mb'
  endif
  assign enable_radius_bottom = section.settings.enable_radius_bottom
  assign enable_radius_top = section.settings.enable_radius_top
%}
{%- capture style -%}
  --section-padding-top: {{ section.settings.padding_top }}px; --section-padding-bottom: {{ section.settings.padding_bottom }}px;
{%- endcapture -%}
{%- capture sizes -%}
  (min-width: {{ settings.page_width }}px) {{ settings.page_width | minus: 100 }}px, (min-width: 750px)
  calc(100vw - 10rem), 100vw
{%- endcapture -%}
<div
  class="color-{{ section.settings.color_scheme }} relative gradient bls__section rich-text section-padding{{ tb_top_spacing }}{{ tb_bottom_spacing }}{{ mb_top_spacing }}{{ mb_bottom_spacing }} {% if enable_radius_bottom %}radius-bottom{% endif %} {% if enable_radius_top %}radius-top{% endif %}"
  style="{{ style | strip | strip_newlines }}"
>
  <div class="section_inner{{ section_width }}">
    <div
      class="rich-text-content  text-{{ section.settings.text_alignment }}"
      style="--max-width: {{ section.settings.content_max_width }}%"
    >
      {%- assign current_image_index = 0 -%}
      {%- for block in section.blocks -%}
        {%- case block.type -%}
          {%- when 'heading' -%}
            <h2
              class="rich-text__heading text-transform-unset {% if block.settings.remove_letter_spacing == blank %} heading-letter-spacing{% endif %} {{ block.settings.heading_size }}{% if block.settings.remove_space %} m-0{% endif %}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
              {% if settings.animations_reveal_on_scroll %}
                style="--animation-order: {{ forloop.index }};"
              {% endif %}
              {{ block.shopify_attributes }}
            >
              {{ block.settings.heading }}
            </h2>
          {%- when 'subheading' -%}
            <div
              class="rich-text-sub-heading text-transform-unset {{ block.settings.subheading_size }}{% if block.settings.remove_space %} mb-10{% endif %}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
              {% if settings.animations_reveal_on_scroll %}
                style="--animation-order: {{ forloop.index }};"
              {% endif %}
              {{ block.shopify_attributes }}
            >
              {{ block.settings.subheading | escape }}
            </div>
          {%- when 'text' -%}
            <div
              class="{% if block.settings.description_font == 'heading_font' %}heading-font z-2 xl:mb-25! relative font-smoothing-initial{% endif %} rich-text__text{% if block.settings.remove_space == false %} mb-15 {% endif %} {{ block.settings.description_size }}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
              {% if settings.animations_reveal_on_scroll %}
                style="--animation-order: {{ forloop.index }};"
              {% endif %}
              {{ block.shopify_attributes }}
            >
              {{ block.settings.text }}
            </div>
          {%- when 'spacing' -%}
            <div
              class="bls__spacing"
              style=" --desktop-height: {{ block.settings.desktop_spacing }}px; --mobile_height: {{ block.settings.mobile_spacing }}px;"
            ></div>
          {%- when 'button' -%}
            {% if block.settings.first_button_label != blank or block.settings.second_button_label != blank %}
              <div class="section-btn d-flex flex-wrap gap-10 justify-content-{{ section.settings.text_alignment }}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
                {% if block.settings.first_button_label != blank %}
                  <a
                    {% if block.settings.first_button_link == blank %}
                      role="link" aria-disabled="true"
                    {% else %}
                      href="{{ block.settings.first_button_link | default: "#" }}"
                    {% endif %}
                    aria-label="{{ block.settings.first_button_label }}"
                    class="btn remove-underline{% if block.settings.first_button_style %} btn-outline{% else %} btn-primary{% endif %}"
                  >
                    {{ block.settings.first_button_label }}
                  </a>
                {% endif %}
                {% if block.settings.second_button_label != blank %}
                  <a
                    {% if block.settings.second_button_link == blank %}
                      role="link" aria-disabled="true"
                    {% else %}
                      href="{{ block.settings.second_button_link | default: "#" }}"
                    {% endif %}
                    aria-label="{{ block.settings.second_button_label }}"
                    class="btn remove-underline {% if block.settings.second_button_style %} btn-outline{% else %} btn-primary{% endif %}"
                  >
                    {{ block.settings.second_button_label }}
                  </a>
                {% endif %}
              </div>
            {% endif %}
          {% when 'image' %}
            {%- assign current_image_index = current_image_index | plus: 1 -%}
            <div
              class="{% if settings.animations_reveal_on_scroll %} scroll-trigger{% endif %} rich-text__image rounded-xl *:rounded-xl *:hover:-translate-y-10 *:transition *:origin-bottom   *:duration-300 overflow-hidden z-1 absolute image-{{ current_image_index }}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
              style="{% if settings.animations_reveal_on_scroll %}--animation-image: {{ current_image_index }};{% endif %}top: {{ block.settings.position_top }}%;left: {{ block.settings.position_left }}%;"
            >
              {% if block.settings.image != blank %}
                {% assign alt = 'image.alt' | t %}
                {%- assign image_alt = block.settings.image.alt | default: alt -%}
                {{
                  block.settings.image
                  | image_url: width: block.settings.image.width
                  | image_tag:
                    loading: 'lazy',
                    sizes: sizes,
                    widths: '375, 750, 1100, 1500, 1780, 2000, 3000, 3840',
                    alt: image_alt
                }}
              {% else %}
                {%- render 'placeholder-render' | type: "blog" | class: 'img-placeholder h-[10rem] w-[10rem]' -%}
              {% endif %}
            </div>
        {%- endcase -%}
      {%- endfor -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "t:sections.rich-text.name",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer", "custom.overlay"]
  },
  "settings": [
    {
      "type": "select",
      "id": "section_width",
      "options": [
        {
          "value": "fix_width",
          "label": "t:sections.all.layout.fix_width"
        },
        {
          "value": "stretch_width",
          "label": "t:sections.all.layout.stretch_width"
        },
        {
          "value": "expand_full_width",
          "label": "t:sections.all.layout.expand_full_width"
        }
      ],
      "default": "stretch_width",
      "label": "t:sections.all.layout.label"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "default-color-scheme"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "options": [
        {
          "value": "left",
          "label": "t:sections.all.text_alignment.option_1.label"
        },
        {
          "value": "center",
          "label": "t:sections.all.text_alignment.option_2.label"
        },
        {
          "value": "right",
          "label": "t:sections.all.text_alignment.option_3.label"
        }
      ],
      "default": "left",
      "label": "t:sections.all.text_alignment.label"
    },
    {
      "type": "range",
      "id": "content_max_width",
      "min": 40,
      "max": 100,
      "unit": "%",
      "default": 100,
      "label": "t:sections.all.content_setting.content_max_width.label",
      "info": "t:sections.all.content_setting.content_max_width.info"
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 40
    }
  ],
  "blocks": [
    {
      "type": "heading",
      "name": "t:sections.rich-text.blocks.heading.name",
      "limit": 3,
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "default": "Talk about your brand",
          "label": "t:sections.rich-text.blocks.heading.settings.heading.label"
        },
        {
          "type": "select",
          "id": "heading_size",
          "options": [
            {
              "value": "h3",
              "label": "t:sections.all.size.small.label"
            },
            {
              "value": "h2",
              "label": "t:sections.all.size.medium.label"
            },
            {
              "value": "fs-40",
              "label": "t:sections.all.size.large.label"
            }
          ],
          "default": "h2",
          "label": "t:sections.all.size.label"
        },
        {
          "type": "checkbox",
          "id": "remove_space",
          "default": false,
          "label": "t:sections.all.remove_space"
        },
        {
          "type": "checkbox",
          "id": "remove_letter_spacing",
          "default": false,
          "label": "t:sections.all.remove_letter_spacing"
        }
      ]
    },
    {
      "type": "subheading",
      "name": "t:sections.all.content_setting.subheading.label",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "subheading",
          "default": "Subheading text",
          "label": "t:sections.all.content_setting.subheading.label"
        },
        {
          "type": "select",
          "id": "subheading_size",
          "options": [
            {
              "value": "text-sm",
              "label": "t:sections.all.size.small.label"
            },
            {
              "value": "text-base",
              "label": "t:sections.all.size.medium.label"
            },
            {
              "value": "text-lg",
              "label": "t:sections.all.size.large.label"
            }
          ],
          "default": "text-sm",
          "label": "t:sections.all.size.label"
        },
        {
          "type": "checkbox",
          "id": "remove_space",
          "default": false,
          "label": "t:sections.all.remove_space"
        }
      ]
    },
    {
      "type": "text",
      "name": "t:sections.all.content_setting.description.label",
      "limit": 3,
      "settings": [
        {
          "type": "richtext",
          "id": "text",
          "default": "<p>Share information about your brand with your customers. Describe a product, make announcements, or welcome customers to your store.</p>",
          "label": "t:sections.rich-text.blocks.text.settings.text.label"
        },
        {
          "type": "select",
          "id": "description_size",
          "options": [
            {
              "value": "",
              "label": "t:sections.all.size.small.label"
            },
            {
              "value": "fs-30",
              "label": "t:sections.all.size.medium.label"
            },
            {
              "value": "fs-40",
              "label": "t:sections.all.size.large.label"
            },
            {
              "label": "t:sections.all.size.extra_large.label",
              "value": "fs-48"
            }
          ],
          "default": "",
          "label": "t:sections.all.size.label"
        },
        {
          "type": "select",
          "id": "description_font",
          "label": "t:settings_schema.typography.settings.menu.font.label",
          "options": [
            {
              "value": "body_font",
              "label": "t:settings_schema.typography.settings.menu.font.body_font"
            },
            {
              "value": "heading_font",
              "label": "t:settings_schema.typography.settings.menu.font.heading_font"
            }
          ],
          "default": "body_font"
        },
        {
          "type": "checkbox",
          "id": "remove_space",
          "default": false,
          "label": "t:sections.all.remove_space"
        }
      ]
    },
    {
      "type": "image",
      "name": "t:sections.rich-text.blocks.image.settings.image.label",
      "limit": 3,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "t:sections.rich-text.blocks.image.settings.image.label"
        },
        {
          "type": "range",
          "id": "position_top",
          "label": "t:sections.rich-text.blocks.image.settings.position_top",
          "min": 0,
          "max": 100,
          "unit": "%",
          "step": 1,
          "default": 50
        },
        {
          "type": "range",
          "id": "position_left",
          "label": "t:sections.rich-text.blocks.image.settings.position_left",
          "min": 0,
          "max": 100,
          "unit": "%",
          "step": 1,
          "default": 50
        }
      ]
    },
    {
      "type": "button",
      "name": "t:sections.all.content_setting.button_label.name",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "first_button_label",
          "default": "Button label",
          "label": "t:sections.all.content_setting.first_button_label.label",
          "info": "t:sections.all.content_setting.button_label.info"
        },
        {
          "type": "url",
          "id": "first_button_link",
          "label": "t:sections.all.content_setting.first_button_label.link"
        },
        {
          "type": "checkbox",
          "id": "first_button_style",
          "label": "t:sections.all.button_style.use_outline_button_style"
        },
        {
          "type": "text",
          "id": "second_button_label",
          "label": "t:sections.all.content_setting.second_button_label.label",
          "info": "t:sections.all.content_setting.button_label.info"
        },
        {
          "type": "url",
          "id": "second_button_link",
          "label": "t:sections.all.content_setting.second_button_label.link"
        },
        {
          "type": "checkbox",
          "id": "second_button_style",
          "label": "t:sections.all.button_style.use_outline_button_style"
        }
      ]
    },
    {
      "type": "spacing",
      "name": "t:sections.all.spacing",
      "limit": 3,
      "settings": [
        {
          "type": "range",
          "id": "desktop_spacing",
          "min": 0,
          "max": 50,
          "step": 1,
          "unit": "px",
          "label": "t:sections.spacing.settings.desktop",
          "info": "t:sections.spacing.settings.desktop_info",
          "default": 15
        },
        {
          "type": "range",
          "id": "mobile_spacing",
          "min": 0,
          "max": 50,
          "step": 1,
          "unit": "px",
          "default": 10,
          "label": "t:sections.spacing.settings.mobile",
          "info": "t:sections.spacing.settings.mobile_info"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.rich-text.presets.name",
      "blocks": [
        {
          "type": "heading"
        },
        {
          "type": "text"
        },
        {
          "type": "spacing"
        },
        {
          "type": "button"
        }
      ]
    }
  ]
}
{% endschema %}
