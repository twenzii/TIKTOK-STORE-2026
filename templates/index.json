ps.\n    <\/p>\n  <\/div>\n\n  <!-- Shopify Newsletter Form -->\n  <div class=\"join-form\">\n    {% form 'customer' %}\n      <input type=\"hidden\" name=\"contact[tags]\" value=\"newsletter\">\n\n      <div class=\"email-input\">\n        <input \n          type=\"email\" \n          id=\"email\" \n          name=\"contact[email]\" \n          placeholder=\"Email Here\" \n          required\n        >\n        <button type=\"submit\" class=\"sign-up-btn\">SIGN UP<\/button>\n      <\/div>\n\n      {% if form.posted_successfully? %}\n        <p class=\"success-message\">You're in. Welcome to the family 🤍<\/p>\n      {% elsif form.errors %}\n        <p class=\"error-message\">Er ging iets mis, probeer het opnieuw.<\/p>\n      {% endif %}\n    {% endform %}\n\n    <div class=\"disclaimer-wrapper\">\n      <p class=\"disclaimer\">\n        <span class=\"bold-italic-text\">Dear Girl<\/span>, this <span class=\"bold-italic-text\">private & exclusive<\/span> club isn’t for everyone, you must be <span class=\"bold-italic-text\">invited<\/span>.\n      <\/p>\n    <\/div>\n  <\/div>\n<\/section>\n\n<style>\n  .join-family {\n    font-family: 'Playfair Display', serif;\n    text-align: left;\n    margin-top: 0px;\n    padding-left: 0px;\n  }\n\n  .join-title {\n    font-size: 5rem;\n    font-weight: normal;\n    color: #4B002A;\n    margin-bottom: 20px;\n  }\n\n  .bold-italic-text {\n    font-weight: bold;\n    font-style: italic;\n  }\n\n  .subheading {\n    font-size: 1.5rem;\n    color: #4B002A;\n    margin-bottom: 30px;\n    margin-top: -10px;\n    line-height: 1.5;\n  }\n\n  .email-input {\n    display: flex;\n    align-items: center;\n    background-color: white;\n    border: 1px solid #4b002a;\n    border-radius: 25px;\n    padding: 1px 20px;\n    margin-right: 10px;\n    width: 40%;\n    position: relative;\n    margin-bottom: 20px;\n  }\n\n  .email-input input {\n    background: transparent;\n    border: none;\n    color: #4B002A;\n    font-size: 1.5rem;\n    padding: 10px;\n    width: 100%;\n  }\n\n  .join-form input::placeholder {\n    color: #4B002A;\n    font-size: 1.5rem;\n    font-weight: bold;\n    font-style: italic;\n  }\n\n  .sign-up-btn {\n    background-color: transparent;\n    color: #4B002A;\n    font-family: 'Playfair Display', serif;\n    font-weight: bold;\n    font-size: 1.5rem;\n    text-decoration: underline;\n    border: none;\n    cursor: pointer;\n    padding: 10px 20px;\n    position: absolute;\n    right: 10px;\n    border-radius: 25px;\n  }\n\n  .disclaimer-wrapper {\n    display: flex;\n    justify-content: flex-start;\n    margin-top: -10px;\n    margin-left: 20px;\n  }\n\n  .disclaimer {\n    font-size: 1.2rem;\n    color: #4B002A;\n    margin-top: 0;\n  }\n\n  .success-message {\n    margin-top: 10px;\n    color: #4B002A;\n    font-weight: bold;\n    font-style: italic;\n  }\n\n  .error-message {\n    margin-top: 10px;\n    color: #b30000;\n    font-weight: bold;\n  }\n\n  @media (max-width: 768px) {\n    .join-title {\n      font-size: 6rem;\n    }\n\n    .subheading {\n      font-size: 2rem;\n    }\n\n    .email-input {\n      width: 100%;\n      margin-bottom: 15px;\n      padding: 1px 15px;\n    }\n\n    .email-input input {\n      font-size: 1.3rem;\n      padding: 8px;\n    }\n\n    .sign-up-btn {\n      font-size: 1.3rem;\n      padding: 8px 15px;\n      right: 5px;\n    }\n\n    .disclaimer {\n      font-size: 1rem;\n    }\n  }\n\n  @media (max-width: 480px) {\n    .join-title {\n      font-size: 5rem;\n    }\n\n    .subheading {\n      font-size: 1.5rem;\n    }\n\n    .email-input input {\n      font-size: 1.2rem;\n    }\n\n    .sign-up-btn {\n      font-size: 1.2rem;\n    }\n  }\n<\/style>\n\n<link href=\"https:\/\/fonts.googleapis.com\/css2?family=Playfair+Display:wght@700&display=swap\" rel=\"stylesheet\">","padding_top":0,"padding_bottom":4}},"ss_instafeed_9_9m8DX9":{"type":"ss-instafeed-9","blocks":{"sub_heading_4tThzR":{"type":"sub_heading","disabled":true,"settings":{"sub_heading":"