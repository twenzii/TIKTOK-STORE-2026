{{ 'section-shopable-image.css' | asset_url | stylesheet_tag }}
<script src="{{ 'section-shop-the-look.js' | asset_url }}" defer="defer"></script>
{%- liquid
  assign section_st = section.settings
  assign theme_st = settings
  assign section_width = ''
  if section_st.section_width == 'fix_width'
    assign section_width = ' container'
  elsif section_st.section_width == 'expand_full_width'
    assign section_width = ' full-width px-20'
  else
    assign section_width = ' full-width-gap'
  endif
  assign enable_parallax_image = section_st.enable_parallax_image
  assign sub_des_size = ''
  assign heading_size = ''
  assign header_size = section_st.heading_size
  if header_size == 'small'
    assign sub_des_size = ' text-xs'
    assign heading_size = ' h3'
  elsif header_size == 'large'
    assign sub_des_size = ' lg:text-base text-sm'
    assign heading_size = ' lg:text-5xl!'
  endif
  assign enable_radius_bottom = section_st.enable_radius_bottom
  assign enable_radius_top = section_st.enable_radius_top
-%}
{%- capture style -%}
--section-padding-top: {{ section_st.padding_top }}px; --section-padding-bottom: {{ section_st.padding_bottom }}px;
{%- endcapture -%}
<div
  class="color-{{ section_st.color_scheme }} gradient bls__section section-padding {% if enable_parallax_image %}parallax-image{% endif %} {% if enable_radius_bottom %}radius-bottom{% endif %} {% if enable_radius_top %}radius-top{% endif %}"
  style="{{ style | strip | strip_newlines }}"
>
  <div class="{{ section_width }}">
    {%- if section_st.title != blank or section_st.description != blank or section_st.subheading != blank -%}
      <div class="bls__section-header mb-30 sm:mb-35 text-{{ section_st.text_alignment }}{% if theme_st.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
        {%- if section_st.subheading != blank -%}
          <p
            class="sub-heading  mb-10! {{ sub_des_size }}"
          >
            {{ section_st.subheading | escape }}
          </p>
        {%- endif -%}
        {%- if section_st.title != blank -%}
          <h2 class="bls_section-heading heading-letter-spacing mb-7 md:mb-15{{ heading_size }}">
            {{ section_st.title }}
          </h2>
        {%- endif -%}
        {%- if section_st.description != blank -%}
          <div class="short-des{{ sub_des_size }}">
            {{ section_st.description }}
          </div>
        {%- endif -%}
      </div>
    {%- endif -%}
    <span class="h-30 bg-white w-full top-0 start-0 absolute z-3 rounded-b-4xl pointer-events-none opacity-0 radius-t"></span>
    <span class="h-30 bg-white w-full start-0 bottom-0 absolute z-3 rounded-t-4xl pointer-events-none opacity-0 radius-b"></span>
    <slide-section
      data-items="1"
      data-gap="{{ section_st.column_gap }}"
      data-controls="{{ section_st.show_navigation }}"
      data-nav="{{ section_st.show_pagination }}"
      data-autoplay="false"
      data-loop="true"
      data-mouse-drag="true"
      data-controls-position="top"
      data-autoplay-button-output="false"
      data-axis="horizontal"
      data-mode="gallery"
      data-psot="false"
      data-speed="1000"
      data-fix-height="false"
      class="slide-shop-the-look relative pagination-{{ section_st.desktop_pagination_position }}"
      aria-label="{{ 'sections.slideshow.slide_label' | t }}"
    >
      <div class="slide-container">
        {% content_for 'blocks' %}
      </div>
    </slide-section>
  </div>
</div>
{% schema %}
{
  "name": "t:sections.shop_the_look.name",
  "tag": "section",
  "class": "section shop-the-look",
  "settings": [
    {
      "type": "select",
      "id": "section_width",
      "options": [
        {
          "value": "fix_width",
          "label": "t:sections.all.layout.fix_width"
        },
        {
          "value": "stretch_width",
          "label": "t:sections.all.layout.stretch_width"
        },
        {
          "value": "expand_full_width",
          "label": "t:sections.all.layout.expand_full_width"
        }
      ],
      "default": "stretch_width",
      "label": "t:sections.all.layout.label"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "default-color-scheme"
    },
    {
      "type": "header",
      "content": "t:sections.all.section_setting.label"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "t:sections.all.content_setting.subheading.label"
    },
    {
      "type": "text",
      "id": "title",
      "label": "t:sections.all.content_setting.heading.label"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "t:sections.all.content_setting.description.label"
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
        {
          "value": "small",
          "label": "t:sections.all.heading_size.options__1.label"
        },
        {
          "value": "medium",
          "label": "t:sections.all.heading_size.options__2.label"
        },
        {
          "value": "large",
          "label": "t:sections.all.heading_size.options__3.label"
        }
      ],
      "default": "medium",
      "label": "t:sections.all.heading_size.label"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "options": [
        {
          "value": "left",
          "label": "t:sections.all.text_alignment.option_1.label"
        },
        {
          "value": "center",
          "label": "t:sections.all.text_alignment.option_2.label"
        },
        {
          "value": "right",
          "label": "t:sections.all.text_alignment.option_3.label"
        }
      ],
      "default": "center",
      "label": "t:sections.all.text_alignment.label"
    },
    {
      "type": "select",
      "id": "aspect_ratio",
      "options": [
        {
          "value": "adapt",
          "label": "t:sections.all.heigth.adapt_to_image"
        },
        {
          "value": "square",
          "label": "t:sections.image-tabs.settings.aspect_ratio.option__1"
        },
        {
          "value": "portrait",
          "label": "t:sections.image-tabs.settings.aspect_ratio.option__2"
        },
        {
          "value": "landscape",
          "label": "t:sections.image-tabs.settings.aspect_ratio.option__3"
        }
      ],
      "default": "adapt",
      "label": "t:sections.image-tabs.settings.aspect_ratio.label"
    },
    {
      "type": "checkbox",
      "id": "enable_parallax_image",
      "default": true,
      "label": "t:sections.shop_the_look.settings.enable_parallax_image.label"
    },
    {
      "type": "header",
      "content": "t:sections.all.carousel.header"
    },
    {
      "type": "checkbox",
      "id": "show_navigation",
      "default": false,
      "label": "t:sections.all.carousel.show_navigation.label"
    },
    {
      "type": "checkbox",
      "id": "show_pagination",
      "default": false,
      "label": "t:sections.all.carousel.show_pagination.label"
    },
    {
      "type": "select",
      "id": "desktop_pagination_position",
      "default": "center",
      "options": [
        {
          "value": "left",
          "label": "t:sections.all.text_alignment.option_1.label"
        },
        {
          "value": "center",
          "label": "t:sections.all.text_alignment.option_2.label"
        },
        {
          "value": "right",
          "label": "t:sections.all.text_alignment.option_3.label"
        },
        {
          "value": "bottom",
          "label": "t:sections.all.image.desktop_position.bottom"
        }
      ],
      "label": "t:sections.all.carousel.desktop_panigation_position.label"
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 40
    },
    {
      "type": "header",
      "content": "t:sections.all.radius.label"
    },
    {
      "type": "checkbox",
      "id": "enable_radius_top",
      "label": "t:sections.all.radius.enable_radius_top",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "enable_radius_bottom",
      "label": "t:sections.all.radius.enable_radius_bottom",
      "default": false
    }
  ],
  "blocks": [
    {
      "type": "group-lookbook"
    }
  ],
  "presets": [
    {
      "name": "t:sections.shop_the_look.name",
      "blocks": [
        {
          "type": "group-lookbook",
          "blocks": [
            {
              "type": "_subheading"
            },
            {
              "type": "_heading"
            },
            {
              "type": "_product-lookbook"
            }
          ]
        },
        {
          "type": "group-lookbook",
          "blocks": [
            {
              "type": "_subheading"
            },
            {
              "type": "_heading"
            },
            {
              "type": "_product-lookbook"
            }
          ]
        },
      ]
    }
  ]
}
{% endschema %}
